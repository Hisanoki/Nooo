--===== NPC FILTER HELPERS =====--
local function isImmortal(hum)
    -- math.huge = invincible; MaxHealth==0 = old Roblox invincible pattern
    return hum.MaxHealth == math.huge
        or hum.Health    == math.huge
        or hum.MaxHealth == 0
end

local function hasDialog(model)
    for _, v in ipairs(model:GetDescendants()) do
        if v:IsA("Dialog") then return true end
    end
    return false
end

-- Returns true if we should SKIP this NPC (npcCheck must be ON)
local function isFiltered(model)
    if not npcCheck then return false end
    local hum = model:FindFirstChildOfClass("Humanoid")
    if not hum then return false end
    return isImmortal(hum) or hasDialog(model)
end

local function isValidNPC(model)
    if not model or not model.Parent then return false end
    if not model:IsA("Model")        then return false end
    if model == LocalPlayer.Character then return false end
    if Players:GetPlayerFromCharacter(model) then return false end
    local hum  = model:FindFirstChildOfClass("Humanoid")
    local root = model:FindFirstChild("HumanoidRootPart")
    return hum ~= nil and root ~= nil
end

--===== STATUS =====--
local function updateStatus()
    local n = 0
    for _ in pairs(npcs) do n += 1 end
    statusLabel.Text = ("Active: %d NPCs"):format(n)
end

--===== NPC CORE =====--
-- Forward declare so applyHitbox callbacks can reference it
local cleanupNPC

local function addESP(npc)
    if npc:FindFirstChild("_ESP") then return npc:FindFirstChild("_ESP") end
    local root = npc:FindFirstChild("HumanoidRootPart")
    if not root then return nil end
    local box = Instance.new("BoxHandleAdornment")
    box.Name        = "_ESP"
    box.Adornee     = root
    box.Size        = root.Size + Vector3.new(4, 4, 4)
    box.Color3      = Color3.fromRGB(255, 120, 120)
    box.Transparency = 0.5
    box.ZIndex      = 5
    box.AlwaysOnTop = true
    box.Parent      = npc
    return box
end

local function applyHitbox(npc, size)
    if not isValidNPC(npc)  then return end
    if npcs[npc]            then return end   -- already processed
    if isFiltered(npc)      then return end   -- filtered by NPC Check

    local hum  = npc:FindFirstChildOfClass("Humanoid")
    if hum and hum.Health <= 0 then return end

    local head = npc:FindFirstChild("Head")
    local root = npc:FindFirstChild("HumanoidRootPart")

    -- Synthesise head if the NPC lacks one
    if not head and root then
        head            = Instance.new("Part")
        head.Name       = "Head"
        head.Size       = Vector3.new(2, 1, 1)
        head.CFrame     = root.CFrame * CFrame.new(0, root.Size.Y / 2 + 1, 0)
        head.Anchored   = false
        head.CanCollide = false
        head.Massless   = true
        head.Transparency = 1
        head.Parent     = npc
        local w = Instance.new("WeldConstraint")
        w.Part0 = root; w.Part1 = head; w.Parent = head
    end
    if not head then return end

    -- Store original size once
    if not head:FindFirstChild("_OrigSize") then
        local v = Instance.new("Vector3Value")
        v.Name  = "_OrigSize"
        v.Value = head.Size
        v.Parent = head
    end

    head.Massless     = true
    head.Size         = Vector3.new(size, size, size)
    head.CanCollide   = false
    head.Transparency = 0.7
    head.Material     = Enum.Material.ForceField

    -- Mesh (if auto-mesh is ON)
    local mesh
    if autoMesh then
        if not head:FindFirstChild("_Mesh") then
            mesh           = Instance.new("SpecialMesh")
            mesh.Name      = "_Mesh"
            mesh.MeshType  = Enum.MeshType.Head
            mesh.Scale     = Vector3.one
            mesh.Parent    = head
        else
            mesh = head:FindFirstChild("_Mesh")
        end
    end

    -- Per-NPC connections (no global Heartbeat needed)
    local conns = {}

    -- Size guard — reads hitboxSize from data, not stale closure
    table.insert(conns, head:GetPropertyChangedSignal("Size"):Connect(function()
        local data = npcs[npc]
        if not data then return end
        local want = Vector3.new(data.hitboxSize, data.hitboxSize, data.hitboxSize)
        if head.Size ~= want then head.Size = want end
    end))

    if hum then
        table.insert(conns, hum.Died:Connect(function() cleanupNPC(npc) end))
    end

    table.insert(conns, npc.AncestryChanged:Connect(function(_, parent)
        if not parent then cleanupNPC(npc) end
    end))

    npcs[npc] = { conns = conns, esp = addESP(npc), mesh = mesh, hitboxSize = size }
    updateStatus()
end

cleanupNPC = function(npc)
    local data = npcs[npc]
    if not data then return end

    discAll(data.conns)

    -- Only restore head properties if NPC still exists in workspace
    if npc and npc.Parent then
        local head = npc:FindFirstChild("Head")
        if head then
            local orig = head:FindFirstChild("_OrigSize")
            if orig then
                head.Size = orig.Value
                safeDes(orig)
            end
            head.Massless     = false
            head.CanCollide   = true
            head.Transparency = 0
            head.Material     = Enum.Material.Plastic
            safeDes(head:FindFirstChild("_Mesh"))
        end
    end

    safeDes(data.esp)
    npcs[npc]     = nil
    lastProc[npc] = nil
    updateStatus()
end

-- Scan the whole workspace in batches
local function scanAll()
    local size  = tonumber(sizeInput.Text) or CFG.SIZE
    local count, batch = 0, 0
    for _, v in ipairs(workspace:GetDescendants()) do
        if isValidNPC(v) and not npcs[v] then
            applyHitbox(v, size)
            count += 1; batch += 1
            if batch >= CFG.BATCH then batch = 0; task.wait() end
        end
    end
    return count
end

-- Debounced apply for new descendants
local function tryApply(model)
    local now = tick()
    if lastProc[model] and now - lastProc[model] < CFG.DEBOUNCE then return end
    lastProc[model] = now
    task.delay(0.15, function()
        if isValidNPC(model) and not npcs[model] then
            applyHitbox(model, tonumber(sizeInput.Text) or CFG.SIZE)
        end
    end)
end

-- Clear everything
local function clearAll()
    for npc in pairs(npcs) do cleanupNPC(npc) end
    discAll(workConns); table.clear(workConns)
    flashStatus(true, "All hitboxes removed")
end

-- Mesh helpers
local function addMeshAll()
    local n = 0
    for _, v in ipairs(workspace:GetDescendants()) do
        if isValidNPC(v) then
            local head = v:FindFirstChild("Head")
            if head and not head:FindFirstChild("_Mesh") then
                local m = Instance.new("SpecialMesh")
                m.Name = "_Mesh"; m.MeshType = Enum.MeshType.Head
                m.Scale = Vector3.one; m.Parent = head
                if npcs[v] then npcs[v].mesh = m end
                n += 1
            end
        end
    end
    return n
end

local function clearMeshAll()
    local n = 0
    for _, v in ipairs(workspace:GetDescendants()) do
        local head = v:FindFirstChild("Head")
        if head then
            local m = head:FindFirstChild("_Mesh")
            if m then m:Destroy(); n += 1 end
        end
    end
    for _, data in pairs(npcs) do data.mesh = nil end
    return n
end

--===== BUTTON EVENTS =====--

-- Auto Hitbox toggle
autoToggle.MouseButton1Click:Connect(function()
    autoHitbox = not autoHitbox
    autoToggle.Text             = "Auto Hitbox: " .. (autoHitbox and "ON" or "OFF")
    autoToggle.BackgroundColor3 = autoHitbox and C.GOOD or C.PRI_D

    -- Always clear old workspace listeners first (prevent stacking)
    discAll(workConns); table.clear(workConns)

    if autoHitbox then
        flashStatus(true, "Scanning...")
        task.spawn(function()
            local n = scanAll()
            flashStatus(true, ("Auto ON → %d NPCs"):format(n))
        end)
        table.insert(workConns, workspace.DescendantAdded:Connect(function(d)
            local m = d:FindFirstAncestorOfClass("Model") or (d:IsA("Model") and d)
            if m then tryApply(m) end
        end))
        table.insert(workConns, workspace.ChildAdded:Connect(function(c)
            if c:IsA("Model") then tryApply(c) end
        end))
    else
        flashStatus(false, "Auto Hitbox OFF")
    end
end)

