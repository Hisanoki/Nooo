--===== SMALL HELPERS =====--
local function discAll(list)
    for _, c in ipairs(list) do pcall(c.Disconnect, c) end
end

local function safeDes(obj)
    if obj and obj.Parent then pcall(obj.Destroy, obj) end
end

local function mkCorner(p, r)
    local u = Instance.new("UICorner", p)
    u.CornerRadius = UDim.new(0, r or 8)
end

local function mkStroke(p, col, th)
    local s = Instance.new("UIStroke", p)
    s.Color = col or C.ACC; s.Thickness = th or 1
end

-- Drag works for BOTH touch and mouse
local function makeDraggable(obj)
    local drag, start, orig = false, nil, nil
    local cam = workspace.CurrentCamera
    obj.InputBegan:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.Touch
        or i.UserInputType == Enum.UserInputType.MouseButton1 then
            drag  = true
            start = i.Position
            orig  = obj.Position
            i.Changed:Connect(function()
                if i.UserInputState == Enum.UserInputState.End then drag = false end
            end)
        end
    end)
    obj.InputChanged:Connect(function(i)
        if not drag then return end
        if i.UserInputType ~= Enum.UserInputType.Touch
        and i.UserInputType ~= Enum.UserInputType.MouseMovement then return end
        local d   = i.Position - start
        local vp  = cam.ViewportSize
        local abs = obj.AbsoluteSize
        obj.Position = UDim2.fromOffset(
            math.clamp(orig.X.Offset + d.X, 0, vp.X - abs.X),
            math.clamp(orig.Y.Offset + d.Y, 0, vp.Y - abs.Y)
        )
    end)
end

-- Button factory
local function mkBtn(parent, text, pos, size, color)
    local btn = Instance.new("TextButton")
    btn.Position         = pos
    btn.Size             = size or UDim2.fromOffset(CFG.W - CFG.PAD * 2, 32)
    btn.BackgroundColor3 = color or C.PRI
    btn.Text             = text
    btn.TextColor3       = C.TXT
    btn.Font             = Enum.Font.GothamBold
    btn.TextSize         = 14
    btn.AutoButtonColor  = false
    btn.Parent           = parent
    mkCorner(btn, 8); mkStroke(btn, C.ACC, 1)

    btn.MouseEnter:Connect(function()
        TweenService:Create(btn, TweenInfo.new(0.12), {BackgroundColor3 = color:Lerp(C.ACC, 0.25)}):Play()
    end)
    btn.MouseLeave:Connect(function()
        TweenService:Create(btn, TweenInfo.new(0.12), {BackgroundColor3 = color}):Play()
    end)
    return btn
end

