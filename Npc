autoToggle.MouseButton1Click:Connect(function()
    autoHitbox = not autoHitbox
    autoToggle.Text             = "Auto Hitbox: " .. (autoHitbox and "ON" or "OFF")
    autoToggle.BackgroundColor3 = autoHitbox and C.GOOD or C.PRI_D

    discAll(workConns); table.clear(workConns)  -- clear old listeners first

    if autoHitbox then
        flashStatus(true, "Scanning...")
        task.spawn(function()
            flashStatus(true, ("Auto ON → %d NPCs"):format(scanAll()))
        end)
        table.insert(workConns, workspace.DescendantAdded:Connect(function(d)
            local m = d:FindFirstAncestorOfClass("Model") or (d:IsA("Model") and d)
            if m then tryApply(m) end
        end))
        table.insert(workConns, workspace.ChildAdded:Connect(function(c)
            if c:IsA("Model") then tryApply(c) end
        end))
    else
        flashStatus(false, "Auto Hitbox OFF")
    end
end)

npcCheckBtn.MouseButton1Click:Connect(function()
    npcCheck = not npcCheck
    npcCheckBtn.Text             = "NPC Check: " .. (npcCheck and "ON" or "OFF")
    npcCheckBtn.BackgroundColor3 = npcCheck and C.GOOD or C.BLUE

    if npcCheck then
        local removed = 0
        for npc in pairs(npcs) do
            if isFiltered(npc) then cleanupNPC(npc); removed += 1 end
        end
        flashStatus(true, ("NPC Check ON — removed %d dialog/immortal"):format(removed))
    else
        flashStatus(false, "NPC Check OFF")
    end
end)

removeAllBtn.MouseButton1Click:Connect(clearAll)

sizeInput.FocusLost:Connect(function()
    local v = tonumber(sizeInput.Text)
    if v and v > 0 and v <= 50 then
        local n = 0
        for npc, data in pairs(npcs) do
            data.hitboxSize = v   -- update BEFORE writing Size (guard reads this)
            local t = data.targetPart
            if t and t.Parent then t.Size = Vector3.new(v, v, v); n += 1 end
        end
        flashStatus(true, ("Updated %d hitboxes → size %g"):format(n, v))
    else
        sizeInput.Text = tostring(CFG.SIZE)
        flashStatus(false, "Invalid size — reset to default")
    end
end)

