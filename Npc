--===== NPC CORE =====--
local cleanupNPC

-- [FIX] ESP dùng SelectionBox bám vào target (hitbox part) thay vì HumanoidRootPart
-- → hiện đúng vị trí & tự scale theo size hitbox, không bị lệch hay xoay sai
local function addESP(npc, target)
    -- Xoá ESP cũ nếu có
    local old = npc:FindFirstChild("_ESP")
    if old then old:Destroy() end

    if not target or not target.Parent then return nil end

    local sel = Instance.new("SelectionBox")
    sel.Name            = "_ESP"
    sel.Adornee         = target          -- bám đúng vào hitbox part
    sel.Color3          = C.ACC           -- amber outline
    sel.LineThickness   = 0.04
    sel.SurfaceTransparency = 0.82
    sel.SurfaceColor3   = C.ACC
    sel.Parent          = npc
    return sel
end

local function enforceSize(target, want)
    if target and target.Parent and target.Size ~= want then
        pcall(function() target.Size = want end)
    end
end

local function applyHitbox(npc, size)
    if not isValidNPC(npc) then return end
    if npcs[npc]           then return end
    if isFiltered(npc)     then return end

    local hum = npc:FindFirstChildOfClass("Humanoid")
    if hum and hum.Health <= 0 then return end

    local synthetic = false
    local target    = npc:FindFirstChild("Head")

    if not target then
        local topPart = findTopPart(npc)
        if not topPart then return end

        local fake        = Instance.new("Part")
        fake.Name         = "Head"
        fake.Size         = Vector3.new(2, 1, 1)
        fake.CFrame       = topPart.CFrame * CFrame.new(0, topPart.Size.Y * 0.5 + 0.5, 0)
        fake.Anchored     = false
        fake.CanCollide   = false
        fake.Massless     = true
        fake.Transparency = 1
        fake.Parent       = npc
        local w = Instance.new("WeldConstraint")
        w.Part0 = topPart; w.Part1 = fake; w.Parent = fake
        target    = fake
        synthetic = true
    end

    origSizes[target] = target.Size
    target.Massless     = true
    target.Size         = Vector3.new(size, size, size)
    target.CanCollide   = false
    target.Transparency = 0.7
    target.Material     = Enum.Material.ForceField

    local conns = {}

    -- Size guard: re-enforce immediately + next frame
    table.insert(conns, target:GetPropertyChangedSignal("Size"):Connect(function()
        local data = npcs[npc]
        if not data then return end
        local w2 = Vector3.new(data.hitboxSize, data.hitboxSize, data.hitboxSize)
        enforceSize(target, w2)
        task.defer(function()
            if npcs[npc] then enforceSize(target, w2) end
        end)
    end))

    -- Periodic re-enforcement every 0.5 s
    table.insert(conns, RunService.Heartbeat:Connect((function()
        local t0 = tick()
        return function()
            if tick() - t0 < 0.5 then return end
            t0 = tick()
            local data = npcs[npc]
            if not data then return end
            local w2 = Vector3.new(data.hitboxSize, data.hitboxSize, data.hitboxSize)
            enforceSize(target, w2)
        end
    end)()))

    if hum then
        table.insert(conns, hum.Died:Connect(function() cleanupNPC(npc) end))
    end

    table.insert(conns, npc.AncestryChanged:Connect(function(_, parent)
        if not parent then cleanupNPC(npc) end
    end))

    npcs[npc] = {
        conns      = conns,
        esp        = addESP(npc, target),   -- [FIX] truyền target để ESP bám đúng hitbox
        hitboxSize = size,
        targetPart = target,
        synthetic  = synthetic,
    }
    updateStatus()
end

cleanupNPC = function(npc)
    local data = npcs[npc]
    if not data then return end

    discAll(data.conns)

    local target = data.targetPart
    if data.synthetic then
        safeDes(target)
    elseif target and target.Parent then
        target.Size         = origSizes[target] or Vector3.new(2, 1, 1)
        target.Massless     = false
        target.CanCollide   = true
        target.Transparency = 0
        target.Material     = Enum.Material.Plastic
    end

    origSizes[target] = nil
    safeDes(data.esp)
    npcs[npc]     = nil
    lastProc[npc] = nil
    updateStatus()
end

local function scanAll()
    local size = tonumber(sizeInput.Text) or CFG.SIZE
    local count, batch = 0, 0
    for _, v in ipairs(workspace:GetDescendants()) do
        if isValidNPC(v) and not npcs[v] then
            applyHitbox(v, size)
            count += 1; batch += 1
            if batch >= CFG.BATCH then batch = 0; task.wait() end
        end
    end
    return count
end

local function tryApply(model)
    if not model or not model.Parent then return end
    local now = tick()
    if lastProc[model] and now - lastProc[model] < CFG.DEBOUNCE then return end
    lastProc[model] = now

    task.delay(0.3, function()
        if npcs[model] then return end
        if isValidNPC(model) then
            applyHitbox(model, tonumber(sizeInput.Text) or CFG.SIZE)
        else
            task.delay(0.7, function()
                if npcs[model] then return end
                if isValidNPC(model) then
                    applyHitbox(model, tonumber(sizeInput.Text) or CFG.SIZE)
                end
            end)
        end
    end)
end

local function clearAll()
    for npc in pairs(npcs) do cleanupNPC(npc) end
    discAll(workConns); table.clear(workConns)
    flashStatus(true, "cleared")
end

