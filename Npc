--===== NPC CORE =====--
local cleanupNPC  -- forward declare

local function addESP(npc)
    if npc:FindFirstChild("_ESP") then return npc:FindFirstChild("_ESP") end
    local root = npc:FindFirstChild("HumanoidRootPart")
    if not root then return nil end
    local box = Instance.new("BoxHandleAdornment")
    box.Name        = "_ESP"
    box.Adornee     = root
    box.Size        = root.Size + Vector3.new(4, 4, 4)
    box.Color3      = Color3.fromRGB(255, 120, 120)
    box.Transparency = 0.5
    box.ZIndex      = 5
    box.AlwaysOnTop = true
    box.Parent      = npc
    return box
end

local function applyHitbox(npc, size)
    if not isValidNPC(npc) then return end
    if npcs[npc]           then return end
    if isFiltered(npc)     then return end

    local hum = npc:FindFirstChildOfClass("Humanoid")
    if hum and hum.Health <= 0 then return end

    local synthetic = false
    local target    = npc:FindFirstChild("Head")

    if not target then
        -- No named Head — find highest visible part (real head position)
        local topPart = findTopPart(npc)
        if not topPart then return end

        -- Synthesise a fake Head welded on top of that part
        local fake        = Instance.new("Part")
        fake.Name         = "Head"
        fake.Size         = Vector3.new(2, 1, 1)
        fake.CFrame       = topPart.CFrame * CFrame.new(0, topPart.Size.Y * 0.5 + 0.5, 0)
        fake.Anchored     = false
        fake.CanCollide   = false
        fake.Massless     = true
        fake.Transparency = 1
        fake.Parent       = npc
        local w = Instance.new("WeldConstraint")
        w.Part0 = topPart; w.Part1 = fake; w.Parent = fake

        target    = fake
        synthetic = true
    end

    -- Store original size in Lua table — no workspace instance, anticheat-safe
    origSizes[target] = target.Size

    target.Massless     = true
    target.Size         = Vector3.new(size, size, size)
    target.CanCollide   = false
    target.Transparency = 0.7
    target.Material     = Enum.Material.ForceField

    local conns = {}

    -- Size guard reads live data.hitboxSize — no stale closure bug
    table.insert(conns, target:GetPropertyChangedSignal("Size"):Connect(function()
        local data = npcs[npc]
        if not data then return end
        local want = Vector3.new(data.hitboxSize, data.hitboxSize, data.hitboxSize)
        if target.Size ~= want then target.Size = want end
    end))

    if hum then
        table.insert(conns, hum.Died:Connect(function() cleanupNPC(npc) end))
    end

    table.insert(conns, npc.AncestryChanged:Connect(function(_, parent)
        if not parent then cleanupNPC(npc) end
    end))

    npcs[npc] = {
        conns      = conns,
        esp        = addESP(npc),
        hitboxSize = size,
        targetPart = target,
        synthetic  = synthetic,
    }
    updateStatus()
end

cleanupNPC = function(npc)
    local data = npcs[npc]
    if not data then return end

    discAll(data.conns)

    local target = data.targetPart
    if data.synthetic then
        safeDes(target)                          -- fake head: just destroy
    elseif target and target.Parent then
        -- Real head: restore from Lua-side table
        target.Size        = origSizes[target] or Vector3.new(2, 1, 1)
        target.Massless    = false
        target.CanCollide  = true
        target.Transparency = 0
        target.Material    = Enum.Material.Plastic
    end

    origSizes[target] = nil
    safeDes(data.esp)
    npcs[npc]     = nil
    lastProc[npc] = nil
    updateStatus()
end

-- Batch workspace scan
local function scanAll()
    local size = tonumber(sizeInput.Text) or CFG.SIZE
    local count, batch = 0, 0
    for _, v in ipairs(workspace:GetDescendants()) do
        if isValidNPC(v) and not npcs[v] then
            applyHitbox(v, size)
            count += 1; batch += 1
            if batch >= CFG.BATCH then batch = 0; task.wait() end
        end
    end
    return count
end

-- Debounced apply for newly added descendants
local function tryApply(model)
    local now = tick()
    if lastProc[model] and now - lastProc[model] < CFG.DEBOUNCE then return end
    lastProc[model] = now
    task.delay(0.15, function()
        if isValidNPC(model) and not npcs[model] then
            applyHitbox(model, tonumber(sizeInput.Text) or CFG.SIZE)
        end
    end)
end

local function clearAll()
    for npc in pairs(npcs) do cleanupNPC(npc) end
    discAll(workConns); table.clear(workConns)
    flashStatus(true, "All hitboxes removed")
end

