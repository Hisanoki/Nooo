--===== CORE HELPERS =====--
local function discAll(list)
    for _, c in ipairs(list) do pcall(c.Disconnect, c) end
end

local function safeDes(obj)
    if obj and obj.Parent then pcall(obj.Destroy, obj) end
end

local function corner(p, r)
    Instance.new("UICorner", p).CornerRadius = UDim.new(0, r or 4)
end

local function stroke(p, col, th, trans)
    local s = Instance.new("UIStroke", p)
    s.Color       = col   or C.ACC
    s.Thickness   = th    or 1
    s.Transparency = trans or 0
end

-- Drag: mouse + touch, clamped to viewport
local function makeDraggable(obj)
    local dragging, dragStart, startPos = false
    local cam = workspace.CurrentCamera
    obj.InputBegan:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.Touch
        or i.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging  = true
            dragStart = i.Position
            startPos  = obj.Position
            i.Changed:Connect(function()
                if i.UserInputState == Enum.UserInputState.End then
                    dragging = false
                end
            end)
        end
    end)
    obj.InputChanged:Connect(function(i)
        if not dragging then return end
        if i.UserInputType ~= Enum.UserInputType.Touch
        and i.UserInputType ~= Enum.UserInputType.MouseMovement then return end
        local delta = i.Position - dragStart
        local vp    = cam.ViewportSize
        local abs   = obj.AbsoluteSize
        obj.Position = UDim2.fromOffset(
            math.clamp(startPos.X.Offset + delta.X, 0, vp.X - abs.X),
            math.clamp(startPos.Y.Offset + delta.Y, 0, vp.Y - abs.Y)
        )
    end)
end

