--===== NPC FILTER =====--
local function isImmortal(hum)
    return hum.MaxHealth == math.huge
        or hum.Health    == math.huge
        or hum.MaxHealth == 0
end

local function isFiltered(model)
    if not npcCheck then return false end
    local hum = model:FindFirstChildOfClass("Humanoid")
    if not hum then return false end
    if isImmortal(hum) then return true end
    return model:FindFirstChildWhichIsA("Dialog", true) ~= nil
end

local function isValidNPC(model)
    if not model or not model.Parent         then return false end
    if not model:IsA("Model")               then return false end
    if model == LocalPlayer.Character        then return false end
    if Players:GetPlayerFromCharacter(model) then return false end
    local hum  = model:FindFirstChildOfClass("Humanoid")
    local root = model:FindFirstChild("HumanoidRootPart")
    return hum ~= nil and root ~= nil
end

--===== FIND NPC ROOT MODEL =====--
local function findNPCRoot(instance)
    local result = nil
    local cur    = instance
    while cur and cur ~= workspace do
        if cur:IsA("Model") and cur:FindFirstChildOfClass("Humanoid") then
            result = cur
        end
        cur = cur.Parent
    end
    return result
end

--===== TOP-PART FINDER =====--
local SKIP = {
    HumanoidRootPart = true, Torso = true, UpperTorso = true,
    LowerTorso = true, LeftFoot = true, RightFoot = true,
    LeftLowerArm = true, RightLowerArm = true,
}

local function findTopPart(model)
    local best, bestY = nil, -math.huge
    for _, v in ipairs(model:GetDescendants()) do
        if v:IsA("BasePart") and not v.Massless and not SKIP[v.Name] then
            local topEdge = v.Position.Y + v.Size.Y * 0.5
            if topEdge > bestY then bestY = topEdge; best = v end
        end
    end
    return best
end

