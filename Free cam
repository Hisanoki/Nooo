-- ==========================================
-- 2. LOGIC ĐIỀU KHIỂN
-- ==========================================
local isFreeCam = false
local currentSpeed = 2
local moveState = { Up = false, Down = false, Left = false, Right = false }

-- ---- Biến xoay Camera ----
local sensitivity    = 0.39        -- +30% so với 0.3
local rotX, rotY     = 0, 0
local isDragging     = false
local lastDragPos    = nil
local dragStartPos   = nil
local activeDragInput = nil        -- *** Lưu đúng object touch đang xoay ***
local DRAG_THRESHOLD = 12

local function initRotFromCamera()
	local look = camera.CFrame.LookVector
	rotY = math.deg(math.asin(math.clamp(look.Y, -1, 1)))
	rotX = math.deg(math.atan2(-look.X, -look.Z))
end

local function buildRotatedCFrame(pos)
	return CFrame.new(pos)
		* CFrame.Angles(0, math.rad(rotX), 0)
		* CFrame.Angles(math.rad(rotY), 0, 0)
end

-- ==========================================
-- 3. BẮT SỰ KIỆN XOAY
-- ==========================================
UserInputService.InputBegan:Connect(function(input, gameProcessed)
	-- Nếu GUI (nút bấm di chuyển) đã ăn input → bỏ qua, không xoay
	if gameProcessed then return end
	if not isFreeCam then return end

	if input.UserInputType == Enum.UserInputType.MouseButton1
		or input.UserInputType == Enum.UserInputType.Touch then

		-- Chỉ nhận ngón xoay nếu chưa có ngón nào đang xoay
		if activeDragInput == nil then
			activeDragInput = input       -- *** Khóa đúng ngón này ***
			dragStartPos    = input.Position
			lastDragPos     = input.Position
			isDragging      = false
		end
	end
end)

UserInputService.InputChanged:Connect(function(input)
	if not isFreeCam then return end

	-- *** Chỉ xử lý đúng ngón đang xoay, bỏ qua mọi ngón khác ***
	if input ~= activeDragInput then return end

	if input.UserInputType == Enum.UserInputType.MouseMovement
		or input.UserInputType == Enum.UserInputType.Touch then

		if not isDragging then
			local dist = (input.Position - dragStartPos).Magnitude
			if dist >= DRAG_THRESHOLD then
				isDragging  = true
				lastDragPos = input.Position
			end
			return
		end

		if lastDragPos then
			local delta = input.Position - lastDragPos
			rotX = rotX - delta.X * sensitivity
			rotY = math.clamp(rotY - delta.Y * sensitivity, -80, 80)
		end
		lastDragPos = input.Position
	end
end)

UserInputService.InputEnded:Connect(function(input)
	-- *** Chỉ kết thúc khi đúng ngón xoay nhấc lên ***
	if input == activeDragInput then
		activeDragInput = nil
		isDragging      = false
		dragStartPos    = nil
		lastDragPos     = nil
	end
end)

-- ---- Bind nút di chuyển ----
local function bindButtonEvents(button, direction)
	button.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1
			or input.UserInputType == Enum.UserInputType.Touch then
			moveState[direction] = true
		end
	end)
	button.InputEnded:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1
			or input.UserInputType == Enum.UserInputType.Touch then
			moveState[direction] = false
		end
	end)
end

bindButtonEvents(btnUp,    "Up")
bindButtonEvents(btnDown,  "Down")
bindButtonEvents(btnLeft,  "Left")
bindButtonEvents(btnRight, "Right")

speedBox.FocusLost:Connect(function()
	local num = tonumber(speedBox.Text)
	if num then
		currentSpeed = math.clamp(num, 0.1, 200)
	else
		speedBox.Text = tostring(currentSpeed)
	end
end)

toggleBtn.MouseButton1Click:Connect(function()
	isFreeCam = not isFreeCam
	controlFrame.Visible = isFreeCam

	if isFreeCam then
		toggleBtn.Text = "Free Cam: ON"
		toggleBtn.BackgroundColor3 = Color3.fromRGB(100, 255, 100)
		camera.CameraType = Enum.CameraType.Scriptable
		initRotFromCamera()
	else
		toggleBtn.Text = "Free Cam: OFF"
		toggleBtn.BackgroundColor3 = Color3.fromRGB(255, 100, 100)
		camera.CameraType = Enum.CameraType.Custom
		if player.Character and player.Character:FindFirstChild("Humanoid") then
			camera.CameraSubject = player.Character.Humanoid
		end
		for k in pairs(moveState) do moveState[k] = false end
		activeDragInput = nil
		isDragging      = false
		dragStartPos    = nil
		lastDragPos     = nil
	end
end)

-- ==========================================
-- 4. VÒNG LẶP CHÍNH
-- ==========================================
RunService.RenderStepped:Connect(function()
	if not isFreeCam then return end

	local pos         = camera.CFrame.Position
	local lookVector  = camera.CFrame.LookVector
	local rightVector = camera.CFrame.RightVector
	local moveDir     = Vector3.new(0, 0, 0)

	if moveState.Up    then moveDir = moveDir + lookVector  end
	if moveState.Down  then moveDir = moveDir - lookVector  end
	if moveState.Right then moveDir = moveDir + rightVector end
	if moveState.Left  then moveDir = moveDir - rightVector end

	if moveDir.Magnitude > 0 then
		pos = pos + (moveDir.Unit * currentSpeed)
	end

	camera.CFrame = buildRotatedCFrame(pos)
end)
