        pcall(function()
            game:GetService("StarterGui"):SetCore("SendNotification",{
                Title = "Position",
                Text = "Invalid numbers! Use: X, Y, Z",
                Duration = 3
            })
        end)
        return
    end

    S.manualPositionCFrame = CFrame.new(x, y, z)

    local char = LocalPlayer.Character
    local hrp = char and char:FindFirstChild("HumanoidRootPart")

    if hrp then
        hrp.CFrame = S.manualPositionCFrame

        pcall(function()
            game:GetService("StarterGui"):SetCore("SendNotification",{
                Title = "Position",
                Text = "Teleported to position!",
                Duration = 3
            })
        end)
    else
