end

local function applyBodyHitbox(character, size)
    if not character then return end
    if not isAlive(character) then return end
    if S.processedBodyChars[character] then
        local hrp = character:FindFirstChild("HumanoidRootPart")
        if hrp and not hrp:FindFirstChild("BodyBoxESP") then
            local box = Instance.new("BoxHandleAdornment")
            box.Name = "BodyBoxESP"
            box.Adornee = hrp
            box.Size = Vector3.new(size, size, size)
            box.Color3 = ESP_COLOR
            box.Transparency = ESP_TRANSPARENCY
            box.ZIndex = 10
            box.AlwaysOnTop = true
            box.Parent = hrp
        end
        return
    end
    local hrp = character:FindFirstChild("HumanoidRootPart")
    if not hrp then return end

    if not hrp:FindFirstChild("OrigBodySize") then
        local sv = Instance.new("Vector3Value")
        sv.Name = "OrigBodySize"
        sv.Value = hrp.Size
        sv.Parent = hrp
    end

    hrp.Size = Vector3.new(size, size, size)
    hrp.CanCollide = false
    hrp.Transparency = 0.5
    hrp.Material = Enum.Material.ForceField

    local box = Instance.new("BoxHandleAdornment")
    box.Name = "BodyBoxESP"
    box.Adornee = hrp
    box.Size = Vector3.new(size, size, size)
    box.Color3 = ESP_COLOR
    box.Transparency = ESP_TRANSPARENCY
    box.ZIndex = 10
    box.AlwaysOnTop = true
    box.Parent = hrp

    S.processedBodyChars[character] = true
end

