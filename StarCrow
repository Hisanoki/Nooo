local function setCharacterTransparency(character, transparency)
    if not character then return end

    for _, d in character:GetDescendants() do
        if d:FindFirstAncestorOfClass("Accessory") then
            continue
        end

        if d:IsA("BasePart") then
            if d.Name == "Head" or d.Name == "HumanoidRootPart" then
                d.Transparency = 0
            else
                d.Transparency = transparency
            end

        elseif d:IsA("Decal") then
            if d.Name == "face" and d.Parent and d.Parent.Name == "Head" then
                d.Transparency = 0
            else
                d.Transparency = transparency
            end
        end
    end
end

local function getHumanoidRootPart()
    local character = LocalPlayer.Character
    if not character then return nil end
    return character:FindFirstChild("HumanoidRootPart")
end

local function isAlive(character)
    if not character then return false end
    local humanoid = character:FindFirstChildOfClass("Humanoid")
    return humanoid and humanoid.Health > 0
end

