local flashDefaults = setmetatable({}, {__mode = "k"})

local function flashButton(btn)
    if not btn then return end

    if not flashDefaults[btn] then
        flashDefaults[btn] = {
            color = btn.BackgroundColor3,
            transparency = btn.BackgroundTransparency
        }
    end

    if btn.BackgroundColor3 ~= Color3.fromRGB(50, 200, 120) or btn.BackgroundTransparency ~= 0 then
        flashDefaults[btn].color = btn.BackgroundColor3
        flashDefaults[btn].transparency = btn.BackgroundTransparency
    end

    flashTokens[btn] = (flashTokens[btn] or 0) + 1
    local myToken = flashTokens[btn]

    btn.BackgroundColor3 = Color3.fromRGB(50, 200, 120)
    btn.BackgroundTransparency = 0

    task.delay(0.15, function()
        if not btn or not btn.Parent then return end
        if flashTokens[btn] ~= myToken then return end

        local original = flashDefaults[btn]
        if not original then return end

        btn.BackgroundColor3 = original.color
        btn.BackgroundTransparency = original.transparency
    end)
end
