-- TOOL AURA function
local function runToolAura()
    local char = LocalPlayer.Character
    if not char then return end
    local root = char:FindFirstChild("HumanoidRootPart")
    if not root then return end
    local function stealOne(tool)
        if not tool or not tool:IsA("Tool") then return end
        local handle = tool:FindFirstChild("Handle")
        if handle then
            local ok = pcall(function() firetouchinterest(root, handle, 0) end)
            if ok then
                task.wait(0.04)
                pcall(function() firetouchinterest(root, handle, 1) end)
                return
            end
        end
        pcall(function() tool.Parent = LocalPlayer.Backpack end)
    end
    for _, obj in pairs(workspace:GetDescendants()) do
        if obj:IsA("Tool") then
            local owned = false
            for _, p in pairs(Players:GetPlayers()) do
                if (p.Character and obj:IsDescendantOf(p.Character)) or (p.Backpack and obj:IsDescendantOf(p.Backpack)) then
                    owned = true; break
                end
            end
            if not owned then stealOne(obj); task.wait(0.04) end
        end
    end
end
local function runEquipAllTools()
    local char = LocalPlayer.Character
    if not char then return end

    local moved = false

    for _, obj in pairs(LocalPlayer.Backpack:GetChildren()) do
        if obj:IsA("Tool") then
            pcall(function()
                obj.Parent = char
            end)
            moved = true
            task.wait(0.03)
        end
    end

    if moved then
        task.wait(0.05)
        refreshFeTools()
    end
end
-- ─── FLOAT BUTTON HELPERS ─────────────────────────────────────────────────────
-- Tạo drag logic riêng cho từng nút, track đúng input object để tránh joystick

local function makeDraggableFloat(btn)
    local fDragging = false
    local fMoved = false
    local fDragStart = nil
    local fDragPos = nil
    local fDragInput = nil  -- track đúng input object

    btn.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1
        or input.UserInputType == Enum.UserInputType.Touch then
            fDragging = true
            fMoved = false
            fDragStart = input.Position
            fDragPos = btn.Position
            fDragInput = input
            input.Changed:Connect(function()
                if input.UserInputState == Enum.UserInputState.End then
                    fDragging = false
                    fDragInput = nil
                end
            end)
        end
    end)

    UserInputService.InputChanged:Connect(function(input)
        -- Chỉ move khi đúng input object đã bắt đầu drag → joystick không can thiệp
        if fDragging and (
    input == fDragInput or 
    input.UserInputType == Enum.UserInputType.MouseMovement
) then
            local delta = input.Position - fDragStart
            if delta.Magnitude > 6 then fMoved = true end
            btn.Position = UDim2.new(
                fDragPos.X.Scale, fDragPos.X.Offset + delta.X,
                fDragPos.Y.Scale, fDragPos.Y.Offset + delta.Y
            )
        end
    end)

    return function() return fMoved end, function() fMoved = false end
end

