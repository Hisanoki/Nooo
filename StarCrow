local _tbDragging = false
local _tbMoved = false
local _tbIsTouch = false
local _tbDragInput = nil
local _tbDragStart = nil
local _tbDragPos = nil
toggleBtn.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        _tbDragging = true
        _tbMoved = false
        _tbIsTouch = false
        _tbDragInput = nil
        _tbDragStart = input.Position
        _tbDragPos = toggleBtn.Position
    elseif input.UserInputType == Enum.UserInputType.Touch then
        _tbDragging = true
        _tbMoved = false
        _tbIsTouch = true
        _tbDragInput = input
        _tbDragStart = input.Position
        _tbDragPos = toggleBtn.Position
        input.Changed:Connect(function()
            if input.UserInputState == Enum.UserInputState.End then
                _tbDragging = false
                _tbDragInput = nil
            end
        end)
    end
end)
toggleBtn.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        _tbDragging = false
    end
end)
UserInputService.InputChanged:Connect(function(input)
    if not _tbDragging then return end
    if not _tbIsTouch and input.UserInputType == Enum.UserInputType.MouseMovement then
        local delta = input.Position - _tbDragStart
        if delta.Magnitude > 6 then _tbMoved = true end
        toggleBtn.Position = UDim2.new(
            _tbDragPos.X.Scale, _tbDragPos.X.Offset + delta.X,
            _tbDragPos.Y.Scale, _tbDragPos.Y.Offset + delta.Y
        )
    elseif _tbIsTouch and input == _tbDragInput then
        local delta = input.Position - _tbDragStart
        if delta.Magnitude > 6 then _tbMoved = true end
        toggleBtn.Position = UDim2.new(
            _tbDragPos.X.Scale, _tbDragPos.X.Offset + delta.X,
            _tbDragPos.Y.Scale, _tbDragPos.Y.Offset + delta.Y
        )
    end
end)

