local function removeTracerESP(player)
    if S.tracerESPObjects[player] then
        pcall(function() S.tracerESPObjects[player]:Remove() end)
        S.tracerESPObjects[player] = nil
    end
end

local function createTracerESP(player)
    if player == LocalPlayer then return end
    removeTracerESP(player)

    local line = Drawing.new("Line")
    line.Visible = false
    line.Thickness = 1.8
    line.Transparency = 1

    local conn
    conn = RunService.RenderStepped:Connect(function()
        if not S.tracerESPEnabled then
            line.Visible = false
            return
        end

        local myChar = LocalPlayer.Character
        local char = player.Character

        if not myChar or not char or not isAlive(char) then
            line.Visible = false
            return
        end

        local hrp = char:FindFirstChild("HumanoidRootPart")
        if not hrp then
            line.Visible = false
            return
        end

        local pos, onScreen = Camera:WorldToViewportPoint(hrp.Position)
        if not onScreen then
            line.Visible = false
            return
        end

        line.From = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y - 8)
        line.To = Vector2.new(pos.X, pos.Y)
        line.Color = getTeamColor(player)
        line.Visible = true
    end)

    S.tracerESPObjects[player] = {
        Line = line,
        Connection = conn
    }
end
--  HEAD HITBOX 
local function removeHeadHitbox(character)
    if not character then return end
    S.processedChars[character] = nil
    removeOutlineChams(character)

    local head = character:FindFirstChild("Head")
    if not head then return end

    local origSize = head:FindFirstChild("OriginalSize")
    if origSize then
        head.Size = origSize.Value
        origSize:Destroy()
    end

    local origColor = head:FindFirstChild("OriginalColor")
    if origColor then
        head.Color = origColor.Value
        origColor:Destroy()
    end

    local meshBackup = head:FindFirstChild("__MeshBackup")
    if meshBackup then
        local realMesh = meshBackup:FindFirstChildOfClass("SpecialMesh") or meshBackup:FindFirstChildOfClass("BlockMesh")
        if realMesh then
            realMesh:Clone().Parent = head
        end
        meshBackup:Destroy()
    end

    head.Transparency = 0
    head.CanCollide = false
    head.Material = Enum.Material.Plastic
    head.Massless = false
end

local function applyHeadHitbox(player, character, size)
    if not player or not character then return end

    local humanoid = character:FindFirstChildOfClass("Humanoid")
    if not humanoid or humanoid.Health <= 0 then
        if S.processedChars[character] then
            removeHeadHitbox(character)
        end
        return
    end

    local head = character:FindFirstChild("Head")
    if not head then return end

    local teamColor = getTeamColor(player)
    local targetSize = Vector3.new(size, size, size)

    if humanoid.Health <= 0 then
        if S.processedChars[character] then
            removeHeadHitbox(character)
        end
        return
    end

    if not head:FindFirstChild("OriginalSize") then
        local sv = Instance.new("Vector3Value")
        sv.Name = "OriginalSize"
        sv.Value = head.Size
        sv.Parent = head
    end

    if not head:FindFirstChild("OriginalColor") then
        local cv = Instance.new("Color3Value")
        cv.Name = "OriginalColor"
        cv.Value = head.Color
        cv.Parent = head
    end

    local meshBackup = head:FindFirstChild("__MeshBackup")
    if not meshBackup then
        local existingMesh = head:FindFirstChildOfClass("SpecialMesh") or head:FindFirstChildOfClass("BlockMesh")
        if existingMesh then
            local folder = Instance.new("Folder")
            folder.Name = "__MeshBackup"
            folder.Parent = head
            existingMesh:Clone().Parent = folder
            existingMesh:Destroy()
        end
    else
        local strayMesh = head:FindFirstChildOfClass("SpecialMesh") or head:FindFirstChildOfClass("BlockMesh")
        if strayMesh then
            strayMesh:Destroy()
        end
    end

    if humanoid.Health <= 0 then
        removeHeadHitbox(character)
        return
    end

    local needsRefresh =
        head.Size ~= targetSize
        or head.Transparency < 0.45 or head.Transparency > 0.55
        or head.Material ~= Enum.Material.ForceField
        or head.CanCollide ~= false
        or head.Massless ~= true
        or head.Color ~= teamColor

    if needsRefresh then
        head.Massless = true
        head.Size = targetSize
        head.CanCollide = false
        head.Transparency = 0.5
        head.Material = Enum.Material.ForceField
        head.Color = teamColor
    end

    if not character:FindFirstChild("StarCrowOutline") then
        addOutlineChams(character)
    end

    if not character:FindFirstChild("__HeadHitboxDeathHook") then
        local tag = Instance.new("BoolValue")
        tag.Name = "__HeadHitboxDeathHook"
        tag.Parent = character

        humanoid.Died:Connect(function()
            if character and character.Parent then
                removeHeadHitbox(character)
            end
        end)

        humanoid:GetPropertyChangedSignal("Health"):Connect(function()
            if humanoid.Health <= 0 then
                if character and character.Parent then
                    removeHeadHitbox(character)
                end
            end
        end)

        task.spawn(function()
            while true do
                task.wait(0.5)

                if not character or not character.Parent then
                    task.wait(2)
                    if not character or not character.Parent then break end
                end

                if not S.autoHitboxEnabled then break end
                if not S.processedChars[character] then break end

                local currentHumanoid = character:FindFirstChildOfClass("Humanoid")
                if not currentHumanoid or currentHumanoid.Health <= 0 then break end

                if not character:FindFirstChild("StarCrowOutline") then
                    addOutlineChams(character)
                end
            end
        end)
    end

    S.processedChars[character] = true
end
--  BODY HITBOX 

local function applyBodyHitbox(character, size)
    if not character then return end
    local hrp = character:FindFirstChild("HumanoidRootPart")
    if not hrp then return end
    pcall(function()
        hrp.Size = Vector3.new(size, size, size)
        hrp.CanCollide = false
        hrp.Transparency = 0.5
        hrp.Material = Enum.Material.ForceField
    end)
    addOutlineChams(character)
end

local function resetBodyHitbox(character)
    if not character then return end
    local hrp = character:FindFirstChild("HumanoidRootPart")
    if not hrp then return end
    pcall(function()
        hrp.Size = Vector3.new(2, 2, 1)
        hrp.Transparency = 1
        hrp.CanCollide = false
        hrp.Material = Enum.Material.Plastic
    end)
    removeOutlineChams(character)
end

