    end

    if S.waitingForKeybind then
        local newKey = input.KeyCode

        if newKey ~= Enum.KeyCode.Unknown then
            if S.waitingForKeybind ~= "Menu" and newKey == (S.menuKeyCode or Enum.KeyCode.RightControl) then
                
            else
                if S.waitingForKeybind == "Invisible" then
                    S.invisKeyCode = newKey
                    INVIS_CONFIG.TOGGLE_KEY = newKey

                    if S.btnRefs.invisBindBtn then
                        S.btnRefs.invisBindBtn.Text = tostring(newKey):gsub("Enum.KeyCode.", "")
                        S.btnRefs.invisBindBtn.BackgroundColor3 = Color3.fromRGB(38, 38, 38)
                        S.btnRefs.invisBindBtn.BackgroundTransparency = 0.35
                    end
                    

                                elseif S.waitingForKeybind == "Fly" then
                    S.flyKeyCode = newKey

                    if S.btnRefs.flyBindBtn then
