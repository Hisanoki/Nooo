local function findUseTool(name)
    local low = name:lower()
    local char = LocalPlayer.Character
    for _, v in ipairs(LocalPlayer.Backpack:GetChildren()) do
        if v:IsA("Tool") and v.Name:lower() == low then return v end
    end
    if char then
        for _, v in ipairs(char:GetChildren()) do
            if v:IsA("Tool") and v.Name:lower() == low then return v end
        end
    end
end

local function doUseTool()
    if S.useCooling then return end
    if not S.feUseInput then return end
    local name = S.feUseInput.Text:match("^%s*(.-)%s*$")
    if name == "" then
        createNotification("Use Tool", "Item name not entered")
        return
    end
    local char = LocalPlayer.Character
    local human = char and char:FindFirstChildOfClass("Humanoid")
    if not char or not human then
        createNotification("Use Tool", "Character not found")
        return
    end
    local tool = findUseTool(name)
    if not tool then
        createNotification("Use Tool", "Not found " .. name)
        return
    end
    S.useCooling = true
    if S.useFloatBtn then S.useFloatBtn.Text = "..." end
    if tool.Parent == LocalPlayer.Backpack then
        human:EquipTool(tool)
        task.wait(0.12)
    end
    local eq = char:FindFirstChildWhichIsA("Tool")
    if eq and eq.Name:lower() == name:lower() then
        eq:Activate()
    else
        createNotification("Use Tool", "Equip failed")
    end
    task.wait(0.28)
    if S.useFloatBtn then S.useFloatBtn.Text = "USE" end
    S.useCooling = false
end
