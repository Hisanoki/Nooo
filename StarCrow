local AUTOCLICK_DELAY_PC = 0.15
local AUTOCLICK_DELAY_MOBILE = 0.08

local function stopAutoClick()
    S.autoClickEnabled = false
    S.autoClickConnection = nil
end

local function doGlobalClick()
    local vim = game:GetService("VirtualInputManager")
    local cam = workspace.CurrentCamera
    if not cam then return end

    local vp = cam.ViewportSize

    local x = math.floor(vp.X * 0.78)
    local y = math.floor(vp.Y * 0.82)

    pcall(function()
        vim:SendMouseButtonEvent(x, y, 0, true, game, 0)
        task.wait()
        vim:SendMouseButtonEvent(x, y, 0, false, game, 0)
    end)
end

local function activateHeldTool()
    local char = LocalPlayer.Character
    if not char then return false end

    local tool = char:FindFirstChildWhichIsA("Tool")
    if not tool then return false end

    pcall(function()
        tool:Activate()
    end)

    return true
end

local function startAutoClick()
    stopAutoClick()
    S.autoClickEnabled = true

    local isMobile = UserInputService.TouchEnabled and not UserInputService.KeyboardEnabled

    S.autoClickConnection = task.spawn(function()
        while S.autoClickEnabled do
            if mainFrame and mainFrame.Visible then
                task.wait(0.1)
            else
                if isMobile then
                    local usedTool = activateHeldTool()

                    if not usedTool then
                        task.wait(0.15)
                    else
                        task.wait(AUTOCLICK_DELAY_MOBILE)
                    end
                else
                    doGlobalClick()
                    task.wait(AUTOCLICK_DELAY_PC)
                end
            end
        end
    end)
end

