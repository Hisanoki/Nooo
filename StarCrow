local function getBestPingValue()
    local ping = nil

    pcall(function()
        local stats = game:GetService("Stats")
        local network = stats:FindFirstChild("Network")
        if not network then return end

        local serverStatsItem = network:FindFirstChild("ServerStatsItem")
        if not serverStatsItem then return end

        local dataPing = serverStatsItem:FindFirstChild("Data Ping")
        if not dataPing then return end

        if typeof(dataPing.GetValue) == "function" then
            local raw = dataPing:GetValue()
            if typeof(raw) == "number" then
                ping = math.floor(raw + 0.5)
                return
            end
        end

        if typeof(dataPing.GetValueString) == "function" then
            local txt = dataPing:GetValueString()
            local n = tonumber(string.match(txt, "%d+"))
            if n then
                ping = n
            end
        end
    end)

    return ping
end
local fpsFrames = 0
local fpsValue = 0
local fpsLastTime = tick()

RunService.RenderStepped:Connect(function()
    fpsFrames += 1
    local now = tick()

    if now - fpsLastTime >= 1 then
        fpsValue = math.floor(fpsFrames / (now - fpsLastTime) + 0.5)
        fpsFrames = 0
        fpsLastTime = now
    end
end)
task.spawn(function()
    while pingLabel and pingLabel.Parent and fpsLabel and fpsLabel.Parent do
        local ping = getBestPingValue()

        if ping then
            pingLabel.Text = "| Ping " .. tostring(ping) .. "ms"

            if ping <= 200 then
                pingLabel.TextColor3 = Color3.fromRGB(70, 255, 120) 
            elseif ping <= 500 then
                pingLabel.TextColor3 = Color3.fromRGB(255, 210, 90)
            else
                pingLabel.TextColor3 = Color3.fromRGB(255, 95, 95)
            end
        else
            pingLabel.Text = "| Ping --ms"
            pingLabel.TextColor3 = Color3.fromRGB(170, 170, 170)
        end

        fpsLabel.Text = "| Fps: " .. tostring(fpsValue)

        if fpsValue >= 50 then
            fpsLabel.TextColor3 = Color3.fromRGB(70, 255, 120) 
        elseif fpsValue >= 30 then
            fpsLabel.TextColor3 = Color3.fromRGB(255, 210, 90)
        else
            fpsLabel.TextColor3 = Color3.fromRGB(255, 95, 95)
        end

        task.wait(0.35)
    end
end)

