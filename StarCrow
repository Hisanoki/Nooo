-- ─── PLAYER MANAGEMENT ────────────────────────────────────────────────────────

local function cleanupPlayerConnections(player)
    if S.playerConnections[player] then
        for _, conn in ipairs(S.playerConnections[player]) do
            pcall(function() conn:Disconnect() end)
        end
        S.playerConnections[player] = nil
    end
end


local function onCharacterReady(player, character)
    local humanoid = character:FindFirstChildOfClass("Humanoid")
    if not humanoid then
        humanoid = character:WaitForChild("Humanoid", 5)
    end
    if not humanoid then return end

    local function applyAll()
        local size = tonumber(S.sizeInput and S.sizeInput.Text) or DEFAULT_HITBOX_SIZE
        if S.autoHitboxEnabled and isAlive(character) then
            applyHeadHitbox(character, size)
        end
        if S.bodyHitboxEnabled and isAlive(character) then
            applyBodyHitbox(character, size)
        end
        if S.boxESPEnabled and isAlive(character) then
            addBoxESP(character, getTeamColor(player), size)
        end
        if (S.espNameAllState or (S.nameESPEnabled and S.selectedPlayers[player])) and isAlive(character) then
            createNameESP(player, character)
        end
        if S.chamsEnabled and isAlive(character) then
            addChams(character, getTeamColor(player))
        end
    end

    applyAll()

    local diedConn = humanoid.Died:Connect(function()
        removeHeadHitbox(character)
        removeBodyHitbox(character)
        removeBoxESP(character)
        removeNameESP(player)
        removeChams(character)
    end)

    local ancestryConn = character.AncestryChanged:Connect(function(_, parent)
        if not parent then
            removeHeadHitbox(character)
            removeBodyHitbox(character)
            removeBoxESP(character)
            removeChams(character)
        end
    end)

    if S.playerConnections[player] then
        table.insert(S.playerConnections[player], diedConn)
        table.insert(S.playerConnections[player], ancestryConn)
    end
end

local function registerPlayer(player)
    if player == LocalPlayer then return end
    if S.playerConnections[player] then return end

    S.playerConnections[player] = {}

    local charAddedConn = player.CharacterAdded:Connect(function(character)
        S.processedChars[character] = nil
        task.wait(0.5)
        onCharacterReady(player, character)
    end)
    table.insert(S.playerConnections[player], charAddedConn)

    if player.Character then
        task.spawn(function()
            task.wait(0.1)
            onCharacterReady(player, player.Character)
        end)
    end
end

local function unregisterPlayer(player)
    cleanupPlayerConnections(player)
    if player.Character then
        removeHeadHitbox(player.Character)
        removeBodyHitbox(player.Character)
        removeBoxESP(player.Character)
        removeChams(player.Character)
    end
    removeNameESP(player)
    S.selectedPlayers[player] = nil
end

