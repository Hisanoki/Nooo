local function toggleWalkFling()
    S.walkflinging = not S.walkflinging

    if S.walkflinging then
        local character = S.speaker.Character
        local humanoid = character and character:FindFirstChildWhichIsA("Humanoid")

        if S.walkFlingHumanoidDiedConn then
            S.walkFlingHumanoidDiedConn:Disconnect()
            S.walkFlingHumanoidDiedConn = nil
        end

        if humanoid then
            S.walkFlingHumanoidDiedConn = humanoid.Died:Connect(function()
                S.walkflinging = false
                if S.walkFlingBtn then
                    S.walkFlingBtn.Text = "WALK FLING : OFF"
                    S.walkFlingBtn.BackgroundColor3 = Color3.fromRGB(38, 38, 38)
                    S.walkFlingBtn.BackgroundTransparency = 0.35
                end
            end)
        end

        task.spawn(function()
            local movel = 0.1

            while S.walkflinging do
                RunService.Heartbeat:Wait()

                local char = S.speaker.Character
                local root = char and char:FindFirstChild("HumanoidRootPart")

                if char and root and root.Parent then
                    local vel = root.Velocity
                    root.Velocity = vel * 10000 + Vector3.new(0, 10000, 0)

                    RunService.RenderStepped:Wait()
                    if root and root.Parent then
                        root.Velocity = vel
                    end

                    RunService.Stepped:Wait()
                    if root and root.Parent then
                        root.Velocity = vel + Vector3.new(0, movel, 0)
                        movel = movel * -1
                    end
                end
            end
        end)
    else
        if S.walkFlingHumanoidDiedConn then
            S.walkFlingHumanoidDiedConn:Disconnect()
            S.walkFlingHumanoidDiedConn = nil
        end
    end
end
