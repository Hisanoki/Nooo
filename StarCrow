local function StartFling()
    if S.FlingActive then return end
    if CountFlingTargets() == 0 then
        S.flingStatusLabel.Text = "No targets selected!"
        task.delay(1.5, function() UpdateFlingStatus() end)
        return
    end
    S.FlingActive = true
    UpdateFlingStatus()
    FlingMessage("Fling Started", "Flinging " .. CountFlingTargets() .. " target(s)", 2)

    spawn(function()
        while S.FlingActive do
            local validTargets = {}
            for name, player in pairs(S.SelectedFlingTargets) do
                if player and player.Parent then
                    validTargets[name] = player
                else
                    S.SelectedFlingTargets[name] = nil
                    local cb = S.FlingPlayerCheckboxes[name]
                    if cb then cb.Checkmark.Visible = false end
                end
            end
            for _, player in pairs(validTargets) do
                if S.FlingActive then
                    SkidFling(player)
                    wait(0.1)
                else
                    break
                end
            end
            UpdateFlingStatus()
            wait(0.5)
        end
    end)
end

local function StopFling()
    if not S.FlingActive then return end
    S.FlingActive = false
    UpdateFlingStatus()
    FlingMessage("Fling Stopped", "Fling has been stopped", 2)
