local function scheduleFeRefresh()
    if S.feRefreshBusy then return end
    S.feRefreshBusy = true

    task.delay(0.06, function()
        S.feRefreshBusy = false
        pcall(function()
            refreshFeTools()
        end)
    end)
end

LocalPlayer.Backpack.ChildAdded:Connect(function(obj)
    if obj:IsA("Tool") then
        scheduleFeRefresh()
    end
end)

LocalPlayer.Backpack.ChildRemoved:Connect(function(obj)
    if obj:IsA("Tool") then
        scheduleFeRefresh()
    end
end)

local function bindFeToolCharacter(char)
    if not char then return end

    char.ChildAdded:Connect(function(obj)
        if obj:IsA("Tool") then
            scheduleFeRefresh()
        end
    end)

    char.ChildRemoved:Connect(function(obj)
        if obj:IsA("Tool") then
            scheduleFeRefresh()
        end
    end)

    local hum = char:FindFirstChildOfClass("Humanoid")
    if hum then
        hum.Died:Connect(function()
            scheduleFeRefresh()
        end)
    end

    scheduleFeRefresh()
end

