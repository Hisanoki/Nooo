local function refreshTools()
    for _, child in pairs(ToolScroll:GetChildren()) do
        if child:IsA("TextButton") or (child:IsA("TextLabel") and child.Name == "EmptyLabel") then
            child:Destroy()
        end
    end
    local seen, order = {}, 0
    local sources = {player.Backpack}
    if player.Character then table.insert(sources, player.Character) end
    for _, src in pairs(sources) do
        for _, obj in pairs(src:GetChildren()) do
            if obj:IsA("Tool") and not seen[obj.Name] then
                seen[obj.Name] = true
                order = order + 1
                local tName = obj.Name
                local tBtn = Instance.new("TextButton", ToolScroll)
                tBtn.Size             = UDim2.new(1, 0, 0, 28)
                tBtn.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
                tBtn.BorderSizePixel  = 0
                tBtn.Text             = tName
                tBtn.TextColor3       = Color3.fromRGB(220, 220, 220)
                tBtn.TextScaled       = true
                tBtn.Font             = Enum.Font.Gotham
                tBtn.LayoutOrder      = order
                Instance.new("UICorner", tBtn).CornerRadius = UDim.new(0, 4)
                tBtn.MouseEnter:Connect(function() tBtn.BackgroundColor3 = Color3.fromRGB(60, 60, 60) end)
                tBtn.MouseLeave:Connect(function() tBtn.BackgroundColor3 = Color3.fromRGB(40, 40, 40) end)
                tBtn.MouseButton1Click:Connect(function()
                    local char = player.Character
                    if not char then return end
                    for _, s in pairs({player.Backpack, char}) do
                        for _, item in pairs(s:GetChildren()) do
                            if item:IsA("Tool") and item.Name == tName then
                                pcall(function() item.Parent = char end)
                            end
                        end
                    end
                end)
            end
        end
    end
    if order == 0 then
        local empty = Instance.new("TextLabel", ToolScroll)
        empty.Name = "EmptyLabel"
        empty.Size = UDim2.new(1, 0, 0, 28)
        empty.BackgroundTransparency = 1
        empty.Text      = "Backpack trong"
        empty.TextColor3 = Color3.fromRGB(100, 100, 100)
        empty.TextScaled = true
        empty.Font       = Enum.Font.Gotham
    end
end

