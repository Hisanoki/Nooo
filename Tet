    for _ in pairs(SelectedFlingTargets) do n = n + 1 end
    return n
end

local function UpdateFlingStatus()
    local count = CountFlingTargets()
    if FlingActive then
        flingStatusLabel.Text      = "Flinging " .. count .. " target(s)"
