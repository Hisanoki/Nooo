    else
        flingStatusLabel.Text      = count .. " target(s) selected"
        flingStatusLabel.TextColor3 = Color3.fromRGB(200, 200, 200)
    end
end

local function RefreshFlingPlayerList()
    for _, child in pairs(flingPlayerList:GetChildren()) do
        if child:IsA("Frame") or child:IsA("TextButton") then child:Destroy() end
    end
    FlingPlayerCheckboxes = {}
    local PlayerList = Players:GetPlayers()
    table.sort(PlayerList, function(a, b) return a.Name:lower() < b.Name:lower() end)
    for _, plr in ipairs(PlayerList) do
        if plr ~= LocalPlayer then
