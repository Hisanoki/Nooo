-- Aura float button
local auraFloatEnabled = false
local auraFloatBtn, auraDragConn = nil, nil

local function destroyAuraFloat()
    if auraDragConn  then auraDragConn:Disconnect();  auraDragConn  = nil end
    if auraFloatBtn  then auraFloatBtn:Destroy();     auraFloatBtn  = nil end
end

local function createAuraFloat()
    destroyAuraFloat()
    auraFloatBtn = Instance.new("TextButton", GUI)
    auraFloatBtn.Size             = UDim2.new(0, 80, 0, 80)
    auraFloatBtn.Position         = UDim2.new(0.5, 50, 0.5, -40)
    auraFloatBtn.BackgroundColor3 = Color3.fromRGB(200, 25, 25)
    auraFloatBtn.BorderSizePixel  = 0
    auraFloatBtn.Text             = "Aura"
    auraFloatBtn.TextColor3       = Color3.fromRGB(255, 255, 255)
    auraFloatBtn.TextScaled       = true
    auraFloatBtn.Font             = Enum.Font.GothamBold
    auraFloatBtn.Active           = true
    auraFloatBtn.ZIndex           = 10
    Instance.new("UICorner", auraFloatBtn).CornerRadius = UDim.new(0, 10)
    local fs = Instance.new("UIStroke", auraFloatBtn)
    fs.Color = Color3.fromRGB(255, 100, 100); fs.Thickness = 2
    local fDragging, fMoved, fDragStart, fDragPos, fDragInput = false, false, nil, nil, nil
    auraFloatBtn.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            fDragging = true; fMoved = false
            fDragStart = input.Position; fDragPos = auraFloatBtn.Position; fDragInput = input
            input.Changed:Connect(function()
                if input.UserInputState == Enum.UserInputState.End then fDragging = false; fDragInput = nil end
            end)
        end
    end)
    auraDragConn = UserInputService.InputChanged:Connect(function(input)
        if fDragging and input == fDragInput and
           (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
            local delta = input.Position - fDragStart
            if delta.Magnitude > 6 then fMoved = true end
            auraFloatBtn.Position = UDim2.new(fDragPos.X.Scale, fDragPos.X.Offset + delta.X, fDragPos.Y.Scale, fDragPos.Y.Offset + delta.Y)
        end
    end)
    UserInputService.InputEnded:Connect(function(input)
        if input == fDragInput then fDragging = false; fDragInput = nil end
    end)
    auraFloatBtn.MouseButton1Click:Connect(function()
        if fMoved then fMoved = false; return end
        runToolAura()
    end)
end

