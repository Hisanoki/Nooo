        bangBtn.Text = "BANG PLAYER : ON"
        bangBtn.BackgroundColor3 = Color3.fromRGB(0, 180, 0)
    else
        bangBtn.Text = "BANG PLAYER : OFF"
        bangBtn.BackgroundColor3 = Color3.fromRGB(200, 40, 110)
        if bangTrack then bangTrack:Stop() end
        return
    end
    local char = LocalPlayer.Character
    if not char then return end
    local humanoid = char:FindFirstChildOfClass("Humanoid")
    local anim = Instance.new("Animation")
    anim.AnimationId = "rbxassetid://5918726674"
    bangTrack = humanoid:LoadAnimation(anim)
    bangTrack:Play()
    spawn(function()
        while BangActive do
            local bChar = LocalPlayer.Character
            if not bChar then task.wait(); continue end
            local bHRP = bChar:FindFirstChild("HumanoidRootPart")
            if not bHRP then task.wait(); continue end
            for _, plr in pairs(SelectedFlingTargets) do
                if not BangActive then break end
                if plr.Character then
                    local targetHRP = plr.Character:FindFirstChild("HumanoidRootPart")
                    if targetHRP then
                        bHRP.CFrame = targetHRP.CFrame * CFrame.new(0, 0, 1)
                        for i = 1, 15 do
                            if not BangActive then break end
                            bHRP.CFrame = targetHRP.CFrame * CFrame.new(0, 0, 1)   task.wait(0.05)
                            if not BangActive then break end
                            bHRP.CFrame = targetHRP.CFrame * CFrame.new(0, 0, 1.5) task.wait(0.05)
                        end
                    end
                end
            end
            task.wait()
        end
    end)
end)

