-- ============================================================
-- DRAG MAIN FRAME (kéo qua TitleBar)
-- ============================================================
do
    local dragging, dragStart, startPos = false, nil, nil

    TitleBar.InputBegan:Connect(function(inp)
        if inp.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging  = true
            dragStart = inp.Position
            startPos  = Main.Position
        end
    end)

    UserInputService.InputEnded:Connect(function(inp)
        if inp.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = false
        end
    end)

    UserInputService.InputChanged:Connect(function(inp)
        if dragging and inp.UserInputType == Enum.UserInputType.MouseMovement then
            local d = inp.Position - dragStart
            Main.Position = UDim2.new(
                startPos.X.Scale, startPos.X.Offset + d.X,
                startPos.Y.Scale, startPos.Y.Offset + d.Y
            )
        end
    end)
end

-- ============================================================
-- DRAG TOGGLE BUTTON (kéo chính nút Toggle)
-- ============================================================
do
    local dragging, dragStart, startPos = false, nil, nil
    local moved = false   -- phân biệt kéo vs click

    ToggleBtn.InputBegan:Connect(function(inp)
        if inp.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging  = true
            moved     = false
            dragStart = inp.Position
            startPos  = ToggleBtn.Position
        end
    end)

    UserInputService.InputEnded:Connect(function(inp)
        if inp.UserInputType == Enum.UserInputType.MouseButton1 and dragging then
            dragging = false
            -- Đồng bộ InvisBtn sau khi thả
            InvisBtn.Position = ToggleBtn.Position
        end
    end)

    UserInputService.InputChanged:Connect(function(inp)
        if dragging and inp.UserInputType == Enum.UserInputType.MouseMovement then
            local d = inp.Position - dragStart
            if math.abs(d.X) > 3 or math.abs(d.Y) > 3 then
                moved = true
            end
            if moved then
                local newPos = UDim2.new(
                    startPos.X.Scale, startPos.X.Offset + d.X,
                    startPos.Y.Scale, startPos.Y.Offset + d.Y
                )
                ToggleBtn.Position = newPos
                InvisBtn.Position  = newPos
            end
        end
    end)

    -- Nếu đã kéo thì không kích hoạt click
    ToggleBtn.MouseButton1Click:Connect(function()
        if moved then
            moved = false
            return
        end
    end)
end
