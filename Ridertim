-- >> HELPER
local function corner(obj, r)
    local c = Instance.new("UICorner")
    c.CornerRadius = UDim.new(0, r or 8)
    c.Parent = obj
end

local function addStroke(obj, color, thick)
    local s = Instance.new("UIStroke")
    s.Color     = color or BLUE_HOVER
    s.Thickness = thick or 1.5
    s.Parent    = obj
end

-- >> SELECT HERO
local function selectHero(name)
    pcall(function()
        local menu = PlayerGui:WaitForChild("Menu", 5)
        local re   = menu
            :WaitForChild("Frame")
            :WaitForChild("LocalScript")
            :WaitForChild("RemoteEvent")
        re:FireServer("Select", name, menu)
    end)
end

