    _mkCorner(6, sliderHolder)

    local track = Instance.new("Frame")
    track.Size = UDim2.new(1, -20, 0, 6)
    track.Position = UDim2.new(0, 10, 0.5, -3)
    track.BackgroundColor3 = Color3.fromRGB(70, 70, 70)
    track.BorderSizePixel = 0
    track.Parent = sliderHolder
    _mkCorner(3, track)

    -- Slider value 1-100 → pixel size 30-130
    local function valToSize(v) return v + 29 end  -- 1→30, 100→129
    local function sizeToVal(s) return math.clamp(s - 29, 1, 100) end
    local curVal = sizeToVal(floatBtnSize)

    local fill = Instance.new("Frame")
    fill.Size = UDim2.new((curVal - 1) / 99, 0, 1, 0)
    fill.BackgroundColor3 = Color3.fromRGB(180, 40, 40)
    fill.BorderSizePixel = 0
    fill.Parent = track
    _mkCorner(3, fill)

    local thumb = Instance.new("Frame")
    thumb.Size = UDim2.new(0, 14, 0, 14)
    thumb.AnchorPoint = Vector2.new(0.5, 0.5)
    thumb.Position = UDim2.new((curVal - 1) / 99, 0, 0.5, 0)
    thumb.BackgroundColor3 = Color3.fromRGB(230, 230, 230)
    thumb.BorderSizePixel = 0
    thumb.ZIndex = 5
    thumb.Parent = track
    _mkCorner(7, thumb)

    -- Invisible hitbox trên toàn track để bắt click/touch dễ hơn
    local sliderBtn = Instance.new("TextButton")
    sliderBtn.Size = UDim2.new(1, 0, 0, 30)
    sliderBtn.Position = UDim2.new(0, 0, 0.5, -15)
    sliderBtn.BackgroundTransparency = 1
    sliderBtn.Text = ""
    sliderBtn.ZIndex = 6
    sliderBtn.Parent = track

    local sDragging = false
    local sInput = nil  -- track đúng input object, tránh joystick/other touch can thiệp

    local function applySlider(screenPos)
        local abs = track.AbsolutePosition
        local sz  = track.AbsoluteSize
        local rel = math.clamp((screenPos.X - abs.X) / sz.X, 0, 1)
        curVal = math.floor(rel * 99) + 1
        floatBtnSize = valToSize(curVal)
        sizeValueLabel.Text = "Float Size: " .. tostring(curVal)
        local fillRel = (curVal - 1) / 99
        fill.Size  = UDim2.new(fillRel, 0, 1, 0)
        thumb.Position = UDim2.new(fillRel, 0, 0.5, 0)
        -- Cập nhật kích thước float button đang hiển thị
        if auraFloatBtn then
            auraFloatBtn.Size = UDim2.new(0, floatBtnSize, 0, floatBtnSize)
        end
        if dropFloatBtn then
            dropFloatBtn.Size = UDim2.new(0, floatBtnSize, 0, floatBtnSize)
        end
    end

    sliderBtn.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1
        or input.UserInputType == Enum.UserInputType.Touch then
            sDragging = true
            sInput = input
            applySlider(input.Position)
            input.Changed:Connect(function()
                if input.UserInputState == Enum.UserInputState.End then
                    sDragging = false
                    sInput = nil
                end
            end)
        end
    end)

    -- InputChanged global - chỉ xử lý đúng input object đã bắt đầu, không bị lẫn joystick mobile
    UserInputService.InputChanged:Connect(function(input)
        if sDragging and input == sInput then
            applySlider(input.Position)
        end
    end)
end
