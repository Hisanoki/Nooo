local function updateTPList()
    for _,v in pairs(tpPlayerList:GetChildren()) do
        if v:IsA("TextButton") then v:Destroy() end
    end
    for _,player in pairs(Players:GetPlayers()) do
        if player ~= LocalPlayer then
            local btn = Instance.new("TextButton")
            btn.Size = UDim2.new(1,-6,0,28)
            btn.Text = player.Name
            btn.BackgroundColor3 = selectedTPPlayers[player] and Color3.fromRGB(80,200,80) or Color3.fromRGB(60,60,60)
            btn.BackgroundTransparency = 0.7
            btn.TextColor3 = Color3.new(1,1,1)
            btn.Font = Enum.Font.Gotham
            btn.TextSize = 14
            btn.BorderSizePixel = 0
            btn.Parent = tpPlayerList
            local c = Instance.new("UICorner"); c.CornerRadius = UDim.new(0,4); c.Parent = btn
            btn.MouseButton1Click:Connect(function()
                selectedTPPlayers = {}
                selectedTPPlayers[player] = true
                updateTPList()
            end)
        end
    end
end

function updatePlayerList()
    for _, child in pairs(playerList:GetChildren()) do
        if child:IsA("TextButton") then child:Destroy() end
    end
    for _, player in pairs(Players:GetPlayers()) do
        if player ~= LocalPlayer then
            local btn = Instance.new("TextButton")
            btn.Size = UDim2.new(1,-6,0,28)
            btn.Text = player.Name
            btn.BackgroundColor3 = selectedPlayers[player] and Color3.fromRGB(80,200,80) or Color3.fromRGB(60,60,60)
            btn.BackgroundTransparency = 0.7
            btn.TextColor3 = Color3.new(1,1,1)
            btn.Font = Enum.Font.Gotham
            btn.TextSize = 14
            btn.BorderSizePixel = 0
            btn.Parent = playerList
            local c = Instance.new("UICorner"); c.CornerRadius = UDim.new(0,4); c.Parent = btn
            btn.MouseButton1Click:Connect(function()
                selectedPlayers[player] = not selectedPlayers[player]
                updatePlayerList()
                if nameESPEnabled then
                    if selectedPlayers[player] then
                        if player.Character then createNameESP(player, player.Character) end
                    else
                        removeNameESP(player)
                    end
                end
            end)
        end
    end
end

