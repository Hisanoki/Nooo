local function ToggleAllFling(select)
    for _, player in ipairs(Players:GetPlayers()) do
        if player ~= LocalPlayer then
            local cb = FlingPlayerCheckboxes[player.Name]
            if cb then
                if select then
                    SelectedFlingTargets[player.Name] = player
                    cb.Checkmark.Visible = true
                else
                    SelectedFlingTargets[player.Name] = nil
                    cb.Checkmark.Visible = false
                end
            end
        end
    end
    UpdateFlingStatus()
end

local function StartFling()
    if FlingActive then return end
    if CountFlingTargets() == 0 then
        flingStatusLabel.Text = "No targets selected!"
        task.delay(1.5, function() UpdateFlingStatus() end)
        return
    end
    FlingActive = true
    UpdateFlingStatus()
    FlingMessage("Fling Started", "Flinging " .. CountFlingTargets() .. " target(s)", 2)

    spawn(function()
        while FlingActive do
            local validTargets = {}
            for name, player in pairs(SelectedFlingTargets) do
                if player and player.Parent then
                    validTargets[name] = player
                else
                    SelectedFlingTargets[name] = nil
                    local cb = FlingPlayerCheckboxes[name]
                    if cb then cb.Checkmark.Visible = false end
                end
            end
            for _, player in pairs(validTargets) do
                if FlingActive then
                    SkidFling(player)
                    wait(0.1)
                else
                    break
                end
            end
            UpdateFlingStatus()
            wait(0.5)
        end
    end)
end

local function StopFling()
    if not FlingActive then return end
    FlingActive = false
    UpdateFlingStatus()
    FlingMessage("Fling Stopped", "Fling has been stopped", 2)
end

