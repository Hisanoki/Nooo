-- ─── HELPERS ──────────────────────────────────────────────────────────────────

local function tableCount(t)
    local n = 0
    for _ in t do n = n + 1 end
    return n
end

local function getTeamColor(player)
    if player.Team and player.Team.TeamColor then
        return player.Team.TeamColor.Color
    end
    return ESP_COLOR
end

local function createNotification(title, text)
    pcall(function()
        StarterGui:SetCore("SendNotification", {
            Title = title,
            Text = text,
            Duration = INVIS_CONFIG.NOTIFICATION_DURATION,
        })
    end)
end

local function setCharacterTransparency(character, transparency)
    if not character then return end
    for _, d in character:GetDescendants() do
        if d:IsA("BasePart") or d:IsA("Decal") then
            d.Transparency = transparency
        end
    end
end

local function getHumanoidRootPart()
    local character = LocalPlayer.Character
    if not character then return nil end
    return character:FindFirstChild("HumanoidRootPart")
end

local function isAlive(character)
    if not character then return false end
    local humanoid = character:FindFirstChildOfClass("Humanoid")
    return humanoid and humanoid.Health > 0
end

-- ─── INVISIBILITY ─────────────────────────────────────────────────────────────

local function playInvisSound()
    if invisSound then invisSound:Play() end
end

local function toggleInvisibility()
    if not LocalPlayer.Character then return end
    isInvisible = not isInvisible
    playInvisSound()

    if isInvisible then
        local hrp = getHumanoidRootPart()
        if not hrp then warn("HumanoidRootPart not found") return end
        local savedCFrame = hrp.CFrame
        LocalPlayer.Character:MoveTo(INVIS_CONFIG.INVISIBILITY_POSITION)
        task.wait(0.15)
        local seat = Instance.new("Seat")
        seat.Name = "invischair"
        seat.Anchored = false
        seat.CanCollide = false
        seat.Transparency = 1
        seat.Size = Vector3.new(2, 0.5, 2)
        seat.Position = INVIS_CONFIG.INVISIBILITY_POSITION
        seat.Parent = workspace
        local weld = Instance.new("Weld")
        weld.Part0 = seat
        weld.Part1 = hrp
        weld.Parent = seat
        task.wait()
        seat.CFrame = savedCFrame
        setCharacterTransparency(LocalPlayer.Character, 0.5)
        if invisButton then
            invisButton.BackgroundColor3 = INVIS_CONFIG.SUCCESS_COLOR
            invisButton.Text = "VISIBLE"
        end
        createNotification("Invisibility ON", "You are now invisible")
    else
        local chair = workspace:FindFirstChild("invischair")
        if chair then chair:Destroy() end
        if LocalPlayer.Character then
            setCharacterTransparency(LocalPlayer.Character, 0)
        end
        if invisButton then
            invisButton.BackgroundColor3 = INVIS_CONFIG.PRIMARY_COLOR
            invisButton.Text = "INVISIBLE"
        end
        createNotification("Invisibility OFF", "You are now visible")
    end
end

-- ─── BOX ESP ──────────────────────────────────────────────────────────────────

local function removeBoxESP(character)
    if not character then return end
    if boxESPObjects[character] then
        pcall(function() boxESPObjects[character]:Destroy() end)
        boxESPObjects[character] = nil
    end
    -- Double-clean
    local head = character:FindFirstChild("Head")
    if head then
        for _, c in head:GetChildren() do
            if c:IsA("BoxHandleAdornment") and c.Name == "BoxCharmESP" then
                c:Destroy()
            end
        end
    end
end

local function addBoxESP(character, color, size)
    if not character or not isAlive(character) then return end
    removeBoxESP(character) -- luôn clean trước khi tạo mới
    local head = character:FindFirstChild("Head")
    if not head or not head:IsA("BasePart") then return end
    local box = Instance.new("BoxHandleAdornment")
    box.Name = "BoxCharmESP"
    box.Adornee = head
    box.Size = Vector3.new(size, size, size)
    box.Color3 = color or ESP_COLOR
    box.Transparency = ESP_TRANSPARENCY
    box.ZIndex = 10
    box.AlwaysOnTop = true
    box.Parent = head
    boxESPObjects[character] = box
end

-- ─── HEAD HITBOX ──────────────────────────────────────────────────────────────

local function removeHeadHitbox(character)
    if not character then return end
    processedChars[character] = nil
    removeBoxESP(character)
    local head = character:FindFirstChild("Head")
    if not head then return end
    -- Restore size
    local origSize = head:FindFirstChild("OriginalSize")
    if origSize then
        head.Size = origSize.Value
        origSize:Destroy()
    end
    -- Restore mesh
    local meshBackup = head:FindFirstChild("__MeshBackup")
    if meshBackup then
        local realMesh = meshBackup:FindFirstChildOfClass("SpecialMesh") or meshBackup:FindFirstChildOfClass("BlockMesh")
        if realMesh then
            realMesh:Clone().Parent = head
        end
        meshBackup:Destroy()
    end
    head.Transparency = 0
    head.CanCollide = true
    head.Material = Enum.Material.Plastic
    head.Massless = false
end

local function applyHeadHitbox(character, size)
    if not character then return end
    if not isAlive(character) then return end
    if processedChars[character] then
        -- Đã có hitbox rồi, chỉ đảm bảo box visual còn sống
        local head = character:FindFirstChild("Head")
        if head then
            local found = false
            for _, c in head:GetChildren() do
                if c:IsA("BoxHandleAdornment") and c.Name == "BoxCharmESP" then
                    found = true; break
                end
            end
            if not found then
                addBoxESP(character, ESP_COLOR, size)
            end
        end
        return
    end

    local head = character:FindFirstChild("Head")
    if not head then return end

    -- Backup size
    if not head:FindFirstChild("OriginalSize") then
        local sv = Instance.new("Vector3Value")
        sv.Name = "OriginalSize"
        sv.Value = head.Size
        sv.Parent = head
    end

    -- Backup mesh
    local existingMesh = head:FindFirstChildOfClass("SpecialMesh") or head:FindFirstChildOfClass("BlockMesh")
    if existingMesh and not head:FindFirstChild("__MeshBackup") then
        local folder = Instance.new("Folder")
        folder.Name = "__MeshBackup"
        folder.Parent = head
        existingMesh:Clone().Parent = folder
        existingMesh:Destroy()
    end

    head.Massless = true
    head.Size = Vector3.new(size, size, size)
    head.CanCollide = false
    head.Transparency = 0.5
    head.Material = Enum.Material.ForceField

    addBoxESP(character, ESP_COLOR, size)
    processedChars[character] = true
end

-- ─── NAME ESP ─────────────────────────────────────────────────────────────────

local function removeNameESP(player)
    if nameESPObjects[player] then
        pcall(function() nameESPObjects[player]:Destroy() end)
        nameESPObjects[player] = nil
    end
end

local function createNameESP(player, char)
    if player == LocalPlayer then return end
    if not char then return end
    local head = char:FindFirstChild("Head")
    if not head then return end
    removeNameESP(player)

    local billboard = Instance.new("BillboardGui")
    billboard.Name = "NameESP"
    billboard.Adornee = head
    billboard.Size = UDim2.new(0, 200, 0, 50)
    billboard.StudsOffset = Vector3.new(0, 2.5, 0)
    billboard.AlwaysOnTop = true
    billboard.MaxDistance = 1000
    billboard.Parent = head

    local nameLabel = Instance.new("TextLabel")
    nameLabel.Size = UDim2.new(1, 0, 0.5, 0)
    nameLabel.BackgroundTransparency = 1
    nameLabel.Text = player.Name
    nameLabel.TextColor3 = getTeamColor(player)
    nameLabel.TextStrokeTransparency = 0
    nameLabel.TextStrokeColor3 = Color3.new(0, 0, 0)
    nameLabel.Font = Enum.Font.GothamBold
    nameLabel.TextSize = 14
    nameLabel.Parent = billboard

    local distanceLabel = Instance.new("TextLabel")
    distanceLabel.Size = UDim2.new(1, 0, 0.5, 0)
    distanceLabel.Position = UDim2.new(0, 0, 0.5, 0)
    distanceLabel.BackgroundTransparency = 1
    distanceLabel.Text = "0m"
    distanceLabel.TextColor3 = TEXT_ESP_COLOR
    distanceLabel.TextStrokeTransparency = 0
    distanceLabel.TextStrokeColor3 = Color3.new(0, 0, 0)
    distanceLabel.Font = Enum.Font.Gotham
    distanceLabel.TextSize = 12
    distanceLabel.Parent = billboard

    local conn
    conn = RunService.Heartbeat:Connect(function()
        if not billboard or not billboard.Parent then
            conn:Disconnect(); return
        end
        if not isAlive(char) then
            billboard.Enabled = false; return
        end
        billboard.Enabled = true
        if LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("Head") and head and head.Parent then
            local dist = (head.Position - LocalPlayer.Character.Head.Position).Magnitude
            distanceLabel.Text = string.format("%.1fm", dist)
            nameLabel.TextColor3 = getTeamColor(player)
        end
    end)

    nameESPObjects[player] = billboard
end

-- ─── PLAYER MANAGEMENT (single source of truth) ───────────────────────────────

local function cleanupPlayerConnections(player)
    if playerConnections[player] then
        for _, conn in ipairs(playerConnections[player]) do
            pcall(function() conn:Disconnect() end)
        end
        playerConnections[player] = nil
    end
end

local function onCharacterReady(player, character)
    -- Wait for humanoid to be accessible
    local humanoid = character:FindFirstChildOfClass("Humanoid")
    if not humanoid then
        humanoid = character:WaitForChild("Humanoid", 5)
    end
    if not humanoid then return end

    -- Apply features based on current state
    local function applyAll()
        local size = tonumber(sizeInput and sizeInput.Text) or DEFAULT_HITBOX_SIZE
        if autoHitboxEnabled and isAlive(character) then
            applyHeadHitbox(character, size)
        end
        if boxESPEnabled and isAlive(character) then
            addBoxESP(character, getTeamColor(player), size)
        end
        if (espNameAllState or (nameESPEnabled and selectedPlayers[player])) and isAlive(character) then
            createNameESP(player, character)
        end
    end

    applyAll()

    -- Cleanup khi chết
    local diedConn = humanoid.Died:Connect(function()
        removeHeadHitbox(character)
        removeBoxESP(character)
        removeNameESP(player)
    end)

    -- Cleanup khi character bị remove khỏi workspace
    local ancestryConn = character.AncestryChanged:Connect(function(_, parent)
        if not parent then
            removeHeadHitbox(character)
            removeBoxESP(character)
        end
    end)

    -- Lưu connections vào slot character (không phải player, vì player có thể respawn)
    table.insert(playerConnections[player] or {}, diedConn)
    table.insert(playerConnections[player] or {}, ancestryConn)
    if playerConnections[player] then
        table.insert(playerConnections[player], diedConn)
        table.insert(playerConnections[player], ancestryConn)
    end
end

local function registerPlayer(player)
    if player == LocalPlayer then return end
    -- Tránh đăng ký 2 lần
    if playerConnections[player] then return end

    playerConnections[player] = {}

    -- CharacterAdded — kích hoạt mỗi lần spawn
    local charAddedConn = player.CharacterAdded:Connect(function(character)
        -- Dọn dẹp state character cũ
        processedChars[character] = nil
        task.wait(0.5) -- Chờ character load xong
        onCharacterReady(player, character)
    end)
    table.insert(playerConnections[player], charAddedConn)

    -- Nếu character đã tồn tại lúc đăng ký
    if player.Character then
        task.spawn(function()
            task.wait(0.1)
            onCharacterReady(player, player.Character)
        end)
    end
end

local function unregisterPlayer(player)
    cleanupPlayerConnections(player)
    if player.Character then
        removeHeadHitbox(player.Character)
        removeBoxESP(player.Character)
    end
    removeNameESP(player)
    selectedPlayers[player] = nil
end

