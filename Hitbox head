    _mkCorner(3, track)

    -- Slider value 1-100 → pixel size 30-130
    local function valToSize(v) return v + 29 end  -- 1→30, 100→129
    local function sizeToVal(s) return math.clamp(s - 29, 1, 100) end
    local curVal = sizeToVal(floatBtnSize)

    local fill = Instance.new("Frame")
    fill.Size = UDim2.new((curVal - 1) / 99, 0, 1, 0)
    fill.BackgroundColor3 = Color3.fromRGB(180, 40, 40)
