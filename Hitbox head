                    SelectedFlingTargets[player.Name] = nil
                    checkmark.Visible = false
                else
                    SelectedFlingTargets[player.Name] = player
                    checkmark.Visible = true
                end
                UpdateFlingStatus()
            end)

            FlingPlayerCheckboxes[player.Name] = {Entry = entry, Checkmark = checkmark}
        end
