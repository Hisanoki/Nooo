local function toggleInvisibility()
    if not LocalPlayer.Character then return end
    isInvisible = not isInvisible
    playInvisSound()

    if isInvisible then
        local hrp = getHumanoidRootPart()
        if not hrp then warn("HumanoidRootPart not found") return end
        local savedCFrame = hrp.CFrame
        LocalPlayer.Character:MoveTo(INVIS_CONFIG.INVISIBILITY_POSITION)
        task.wait(0.15)

        local seat = Instance.new("Seat")
        seat.Name = "invischair"
        seat.Anchored = false
        seat.CanCollide = false
        seat.Transparency = 1
        seat.Size = Vector3.new(2, 0.5, 2)
        seat.Position = INVIS_CONFIG.INVISIBILITY_POSITION
        seat.Parent = workspace

        local weld = Instance.new("Weld")
        weld.Part0 = seat
        weld.Part1 = hrp
        weld.Parent = seat

        task.wait()
        seat.CFrame = savedCFrame

        setCharacterTransparency(LocalPlayer.Character, 0.5)
        if invisButton then
            invisButton.BackgroundColor3 = Color3.fromRGB(50, 200, 120)
            invisButton.BackgroundTransparency = 0
            invisButton.Text = "Invisible: ON"
        end
        createNotification("Invisible ON", "You are now invisible")
    else
        local chair = workspace:FindFirstChild("invischair")
        if chair then chair:Destroy() end

        if LocalPlayer.Character then
            setCharacterTransparency(LocalPlayer.Character, 0)
        end

        if invisButton then
            invisButton.BackgroundColor3 = Color3.fromRGB(38, 38, 38)
            invisButton.BackgroundTransparency = 0.35
            invisButton.Text = "Invisible: OFF"
        end
        createNotification("Invisible OFF", "You are now visible")
    end
end
-- ─── BOX ESP ──────────────────────────────────────────────────────────────────

local function removeBoxESP(character)
    if not character then return end
    if boxESPObjects[character] then
        pcall(function() boxESPObjects[character]:Destroy() end)
        boxESPObjects[character] = nil
    end
    local head = character:FindFirstChild("Head")
    if head then
        for _, c in head:GetChildren() do
            if c:IsA("BoxHandleAdornment") and c.Name == "BoxCharmESP" then
                c:Destroy()
            end
        end
    end
end

local function addBoxESP(character, color, size)
    if not character or not isAlive(character) then return end
    removeBoxESP(character)
    local head = character:FindFirstChild("Head")
    if not head or not head:IsA("BasePart") then return end
    local box = Instance.new("BoxHandleAdornment")
    box.Name = "BoxCharmESP"
    box.Adornee = head
    box.Size = Vector3.new(size, size, size)
    box.Color3 = color or ESP_COLOR
    box.Transparency = ESP_TRANSPARENCY
    box.ZIndex = 10
    box.AlwaysOnTop = true
    box.Parent = head
    boxESPObjects[character] = box
end

-- ─── HEAD HITBOX ──────────────────────────────────────────────────────────────

local function removeHeadHitbox(character)
    if not character then return end
    processedChars[character] = nil
    removeBoxESP(character)
    local head = character:FindFirstChild("Head")
    if not head then return end
    local origSize = head:FindFirstChild("OriginalSize")
    if origSize then
        head.Size = origSize.Value
        origSize:Destroy()
    end
    local meshBackup = head:FindFirstChild("__MeshBackup")
    if meshBackup then
        local realMesh = meshBackup:FindFirstChildOfClass("SpecialMesh") or meshBackup:FindFirstChildOfClass("BlockMesh")
        if realMesh then
            realMesh:Clone().Parent = head
        end
        meshBackup:Destroy()
    end
    head.Transparency = 0
    head.CanCollide = true
    head.Material = Enum.Material.Plastic
    head.Massless = false
end

local function applyHeadHitbox(character, size)
    if not character then return end
    if not isAlive(character) then return end
    if processedChars[character] then
        local head = character:FindFirstChild("Head")
        if head then
            local found = false
            for _, c in head:GetChildren() do
                if c:IsA("BoxHandleAdornment") and c.Name == "BoxCharmESP" then
                    found = true; break
                end
            end
            if not found then
                addBoxESP(character, ESP_COLOR, size)
            end
        end
        return
    end

    local head = character:FindFirstChild("Head")
    if not head then return end

    if not head:FindFirstChild("OriginalSize") then
        local sv = Instance.new("Vector3Value")
        sv.Name = "OriginalSize"
        sv.Value = head.Size
        sv.Parent = head
    end

    local existingMesh = head:FindFirstChildOfClass("SpecialMesh") or head:FindFirstChildOfClass("BlockMesh")
    if existingMesh and not head:FindFirstChild("__MeshBackup") then
        local folder = Instance.new("Folder")
        folder.Name = "__MeshBackup"
        folder.Parent = head
        existingMesh:Clone().Parent = folder
        existingMesh:Destroy()
    end

    head.Massless = true
    head.Size = Vector3.new(size, size, size)
    head.CanCollide = false
    head.Transparency = 0.5
    head.Material = Enum.Material.ForceField

    addBoxESP(character, ESP_COLOR, size)
    processedChars[character] = true
end

