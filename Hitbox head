local function updateTPList()
    for _,v in pairs(tpPlayerList:GetChildren()) do
        if v:IsA("TextButton") then v:Destroy() end
    end
    for _,player in pairs(Players:GetPlayers()) do
        if player ~= LocalPlayer then
            local btn = Instance.new("TextButton")
            btn.Size = UDim2.new(1,-6,0,28)
            btn.Text = player.Name
            btn.BackgroundColor3 = selectedTPPlayers[player] and Color3.fromRGB(50, 200, 120) or Color3.fromRGB(38, 38, 38)
btn.BackgroundTransparency = selectedTPPlayers[player] and 0 or 0.35
            btn.TextColor3 = Color3.new(1,1,1)
            btn.Font = Enum.Font.Gotham
            btn.TextSize = 14
            btn.BorderSizePixel = 0
            btn.Parent = tpPlayerList
            local c = Instance.new("UICorner"); c.CornerRadius = UDim.new(0,4); c.Parent = btn
            btn.MouseButton1Click:Connect(function()
                selectedTPPlayers = {}
                selectedTPPlayers[player] = true
                updateTPList()
            end)
        end
    end
end

function updatePlayerList()
    for _, child in pairs(playerList:GetChildren()) do
        if child:IsA("TextButton") then child:Destroy() end
    end
    for _, player in pairs(Players:GetPlayers()) do
        if player ~= LocalPlayer then
