            btn.Text = player.Name
           btn.BackgroundColor3 = selectedPlayers[player] and Color3.fromRGB(50, 200, 120) or Color3.fromRGB(38, 38, 38)
btn.BackgroundTransparency = selectedPlayers[player] and 0 or 0.35
            btn.TextColor3 = Color3.new(1,1,1)
