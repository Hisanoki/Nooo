-- Tạo drag logic riêng cho từng nút, track đúng input object để tránh joystick

local function makeDraggableFloat(btn)
    local fDragging = false
    local fMoved = false
    local fDragStart = nil
    local fDragPos = nil
    local fDragInput = nil  -- track đúng input object

    btn.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1
        or input.UserInputType == Enum.UserInputType.Touch then
            fDragging = true
            fMoved = false
            fDragStart = input.Position
            fDragPos = btn.Position
            fDragInput = input
            input.Changed:Connect(function()
                if input.UserInputState == Enum.UserInputState.End then
                    fDragging = false
                    fDragInput = nil
                end
            end)
        end
    end)

    UserInputService.InputChanged:Connect(function(input)
        -- Chỉ move khi đúng input object đã bắt đầu drag → joystick không can thiệp
        if fDragging and input == fDragInput then
            local delta = input.Position - fDragStart
            if delta.Magnitude > 6 then fMoved = true end
            btn.Position = UDim2.new(
                fDragPos.X.Scale, fDragPos.X.Offset + delta.X,
                fDragPos.Y.Scale, fDragPos.Y.Offset + delta.Y
            )
        end
    end)

    return function() return fMoved end, function() fMoved = false end
end

