-- Chỉ xử lý edge-case: player respawn mà CharacterAdded bị miss, KHÔNG tạo connection mới
task.spawn(function()
    while true do
        task.wait(2)
        if autoHitboxEnabled then
            local size = tonumber(sizeInput.Text) or DEFAULT_HITBOX_SIZE
            for _, player in pairs(Players:GetPlayers()) do
                if player ~= LocalPlayer then
                    local char = player.Character
                    if char and isAlive(char) then
                        -- Đảm bảo player đã được register
                        if not playerConnections[player] then
                            registerPlayer(player)
                        end
                        -- Apply hitbox nếu chưa có
                        applyHeadHitbox(char, size)
                    end
                end
            end
            statusLabel.Text = "Processing: " .. tableCount(processedChars) .. " Players"
        end
    end
end)

