local function toggleWalkFling()
    walkflinging = not walkflinging

    if walkflinging then
        local character = speaker.Character
        local humanoid = character and character:FindFirstChildWhichIsA("Humanoid")

        if walkFlingHumanoidDiedConn then
            walkFlingHumanoidDiedConn:Disconnect()
            walkFlingHumanoidDiedConn = nil
        end

        if humanoid then
            walkFlingHumanoidDiedConn = humanoid.Died:Connect(function()
                walkflinging = false
                if walkFlingBtn then
                    walkFlingBtn.Text = "WALK FLING : OFF"
                    walkFlingBtn.BackgroundColor3 = Color3.fromRGB(38, 38, 38)
                    walkFlingBtn.BackgroundTransparency = 0.35
                end
            end)
        end

        task.spawn(function()
            local movel = 0.1

            while walkflinging do
                RunService.Heartbeat:Wait()

                local char = speaker.Character
                local root = char and char:FindFirstChild("HumanoidRootPart")

                if char and root and root.Parent then
                    local vel = root.Velocity
                    root.Velocity = vel * 10000 + Vector3.new(0, 10000, 0)

                    RunService.RenderStepped:Wait()
                    if root and root.Parent then
                        root.Velocity = vel
                    end

                    RunService.Stepped:Wait()
                    if root and root.Parent then
                        root.Velocity = vel + Vector3.new(0, movel, 0)
                        movel = movel * -1
                    end
                end
            end
        end)
    else
        if walkFlingHumanoidDiedConn then
            walkFlingHumanoidDiedConn:Disconnect()
            walkFlingHumanoidDiedConn = nil
        end
    end
end
