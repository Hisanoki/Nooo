UserInputService.InputBegan:Connect(function(input, gameProcessed)
    if input.UserInputType ~= Enum.UserInputType.Keyboard then
        return
    end

    -- Tool Aura keybind: luôn ưu tiên bắt phím E
    if input.KeyCode == auraKey and not auraListening then
        runToolAura()
        return
    end

    -- Các phím khác mới bị chặn nếu UI đang ăn input
    if gameProcessed then
        return
    end

    if input.KeyCode == INVIS_CONFIG.TOGGLE_KEY then
        toggleInvisibility()
    end

    if input.KeyCode == Enum.KeyCode.LeftControl then
        mainFrame.Visible = not mainFrame.Visible
        mainContainer.Visible = not mainFrame.Visible

        if mainFrame.Visible then
            updatePlayerList()
        end
    end
end)

