-- TOOL AURA function
local function runToolAura()
    local char = LocalPlayer.Character
    if not char then return end
    local root = char:FindFirstChild("HumanoidRootPart")
    if not root then return end
    local function stealOne(tool)
        if not tool or not tool:IsA("Tool") then return end
        local handle = tool:FindFirstChild("Handle")
        if handle then
            local ok = pcall(function() firetouchinterest(root, handle, 0) end)
            if ok then
                task.wait(0.04)
                pcall(function() firetouchinterest(root, handle, 1) end)
                return
            end
        end
        pcall(function() tool.Parent = LocalPlayer.Backpack end)
    end
    for _, obj in pairs(workspace:GetDescendants()) do
        if obj:IsA("Tool") then
            local owned = false
            for _, p in pairs(Players:GetPlayers()) do
                if (p.Character and obj:IsDescendantOf(p.Character)) or (p.Backpack and obj:IsDescendantOf(p.Backpack)) then
                    owned = true; break
                end
            end
            if not owned then stealOne(obj); task.wait(0.04) end
        end
    end
end

