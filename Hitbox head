local function refreshFeTools()
    for _, child in pairs(feToolScroll:GetChildren()) do
        if child:IsA("TextButton") or (child:IsA("TextLabel") and child.Name == "EmptyLabel") then
            child:Destroy()
        end
    end

    local char = LocalPlayer.Character
    local seen = {}
    local toolList = {}

    -- Tool trong Backpack = nằm trên
    for _, obj in pairs(LocalPlayer.Backpack:GetChildren()) do
        if obj:IsA("Tool") and not seen[obj.Name] then
            seen[obj.Name] = true
            table.insert(toolList, {
                Name = obj.Name,
                Equipped = false
            })
        end
    end

    -- Tool đang equip trong Character = nằm dưới
    if char then
        for _, obj in pairs(char:GetChildren()) do
            if obj:IsA("Tool") and not seen[obj.Name] then
                seen[obj.Name] = true
                table.insert(toolList, {
                    Name = obj.Name,
                    Equipped = true
                })
            end
        end
    end

    for order, data in ipairs(toolList) do
        local tName = data.Name

        local tBtn = Instance.new("TextButton")
        tBtn.Parent = feToolScroll
        tBtn.Size = UDim2.new(1, 0, 0, 22)
        tBtn.BackgroundColor3 = Color3.fromRGB(38, 38, 38)
        tBtn.BackgroundTransparency = 0.35
        tBtn.BorderSizePixel = 0
        tBtn.Text = data.Equipped and (tName .. " [EQUIPPED]") or tName
        tBtn.TextColor3 = data.Equipped and Color3.fromRGB(140, 255, 170) or Color3.fromRGB(230, 230, 230)
        tBtn.TextScaled = false
        tBtn.TextSize = 11
        tBtn.Font = Enum.Font.GothamMedium
        tBtn.TextXAlignment = Enum.TextXAlignment.Left
        tBtn.LayoutOrder = order

        local tc = Instance.new("UICorner", tBtn)
        tc.CornerRadius = UDim.new(0, 4)

        local pad = Instance.new("UIPadding", tBtn)
        pad.PaddingLeft = UDim.new(0, 8)
        pad.PaddingRight = UDim.new(0, 6)

        tBtn.MouseButton1Click:Connect(function()
            local char = LocalPlayer.Character
            if not char then return end

            -- đang equip rồi thì thôi
            if data.Equipped then
                return
            end

            local tool = LocalPlayer.Backpack:FindFirstChild(tName)
            if tool and tool:IsA("Tool") then
                pcall(function()
                    tool.Parent = char
                end)
            end

            task.wait(0.05)
            refreshFeTools()
        end)
    end

    if #toolList == 0 then
        local empty = Instance.new("TextLabel")
        empty.Parent = feToolScroll
        empty.Name = "EmptyLabel"
        empty.Size = UDim2.new(1, 0, 0, 22)
